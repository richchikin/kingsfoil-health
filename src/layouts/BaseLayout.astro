---
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import '@styles/tokens.css';
import { getImage } from 'astro:assets';
import defaultOgSource from '@assets/images/team-huddle.jpg';

interface BreadcrumbItem { name: string; url: string; }

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  breadcrumbs?: BreadcrumbItem[];
}

// TODO: create a branded 1200x630 OG image and import it here instead of team-huddle.jpg.
const {
  title,
  description,
  canonicalPath = '',
  ogImage,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  breadcrumbs,
} = Astro.props;
const siteUrl = 'https://kingsfoilhealth.com'; // Replace with actual domain
const canonical = `${siteUrl}${canonicalPath}`;

// Generate optimized OG image URL from default source (or use passed override)
const ogDefault = await getImage({
  src: defaultOgSource,
  width: 1200,
  height: 630,
  format: 'jpg',
});
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}${ogDefault.src}`;

const breadcrumbSchema = breadcrumbs && breadcrumbs.length ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.name,
    item: b.url.startsWith('http') ? b.url : `${siteUrl}${b.url}`,
  })),
} : null;

// Site-wide Organization / InsuranceAgency JSON-LD
// TODO: fill in streetAddress, telephone, email, and sameAs social URLs when available
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': ['InsuranceAgency', 'Organization'],
  '@id': `${siteUrl}/#organization`,
  name: 'Kingsfoil Health',
  legalName: 'Resilience Stack, LLC',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/images/logo-horizontal.svg`,
  },
  description: 'A modern health insurance brokerage helping forward-thinking businesses take control of their benefits through proactive claims management, concierge employee support, and alternative plan structures.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Lehi',
    addressRegion: 'UT',
    addressCountry: 'US',
    // TODO: add streetAddress and postalCode
  },
  areaServed: {
    '@type': 'Country',
    name: 'United States',
  },
  // TODO: add telephone, email, and sameAs (LinkedIn, etc.) once available
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#2e9582">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>

  <!-- Open Graph -->
  <meta property="og:site_name" content="Kingsfoil Health">
  <meta property="og:locale" content="en_US">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImageUrl}>
  <meta property="og:url" content={canonical}>
  <meta property="og:type" content={ogType}>
  {ogType === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime}>
  )}
  {ogType === 'article' && articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime}>
  )}
  {ogType === 'article' && articleAuthor && (
    <meta property="article:author" content={articleAuthor}>
  )}
  {ogType === 'article' && articleSection && (
    <meta property="article:section" content={articleSection}>
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageUrl}>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,700&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" onload="this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,700&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"></noscript>

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FDEL3LJJM9"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-FDEL3LJJM9');
  </script>

  <!-- Netlify Identity (only needed on /admin) -->
  <script>
    if (window.location.pathname.startsWith('/admin')) {
      const s = document.createElement('script');
      s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
      document.head.appendChild(s);
    }
  </script>

  <!-- Site-wide Organization / InsuranceAgency structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

  <!-- Page-specific head content -->
  <slot name="head" />

  <style is:inline>
    .floating-cta {
      position: fixed;
      bottom: 40px;
      right: 40px;
      z-index: 900;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 600;
      background: var(--elm-500);
      color: #fff;
      text-decoration: none;
      padding: 16px 28px;
      border-radius: 50px;
      box-shadow: 0 6px 24px rgba(46, 149, 130, 0.45), 0 2px 8px rgba(0,0,0,0.08);
      transition: background var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast);
    }
    .floating-cta:hover {
      background: var(--elm-600);
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(46, 149, 130, 0.55), 0 4px 12px rgba(0,0,0,0.1);
    }
    .floating-cta:focus-visible {
      box-shadow: var(--focus-ring);
    }
    @media (max-width: 768px) {
      .floating-cta {
        bottom: 24px;
        right: 24px;
        font-size: 15px;
        padding: 14px 22px;
      }
    }
  </style>
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <Nav currentPath={canonicalPath} />

  <main id="main">
    <slot />
  </main>

  <Footer />

  <!-- GA4 Custom Events -->
  <script>
    if (typeof gtag === 'function') {
      // Track CTA clicks
      document.querySelectorAll('.btn-primary, .btn-warm, .nav-cta').forEach(btn => {
        btn.addEventListener('click', () => {
          gtag('event', 'cta_click', {
            cta_text: btn.textContent.trim(),
            page_section: btn.closest('section')?.getAttribute('aria-labelledby') || 'nav'
          });
        });
      });

      // Track article read depth (75%)
      const articleBody = document.querySelector('.article-body');
      if (articleBody) {
        let tracked = false;
        window.addEventListener('scroll', () => {
          if (tracked) return;
          const rect = articleBody.getBoundingClientRect();
          const scrolled = (window.innerHeight - rect.top) / rect.height;
          if (scrolled > 0.75) {
            tracked = true;
            gtag('event', 'article_read', {
              article_title: document.title,
              scroll_depth: '75%'
            });
          }
        }, { passive: true });
      }

      // Track form submissions
      document.querySelectorAll('form').forEach(form => {
        form.addEventListener('submit', () => {
          const formType = form.closest('.form-card') ? 'contact' :
                           form.closest('.newsletter') ? 'newsletter' :
                           form.closest('.gate-form') ? 'resource_download' : 'other';
          gtag('event', 'form_submit', { form_type: formType });
        });
      });

      // Track learning track starts
      document.querySelectorAll('.track-link, .track-card').forEach(link => {
        link.addEventListener('click', () => {
          gtag('event', 'track_start', {
            track_name: link.querySelector('h3')?.textContent || link.textContent.trim()
          });
        });
      });
    }
  </script>

  <!-- Netlify Identity redirect after login -->
  <script>
    if (window.location.pathname.startsWith('/admin') && window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>

  <!-- Floating CTA -->
  <a href="https://calendly.com/kingsfoilhealth-jonathan/30-min-with-jonathan-engle"
     target="_blank"
     rel="noopener noreferrer"
     class="floating-cta"
     aria-label="Schedule a call with Kingsfoil Health">
    Talk to Us
  </a>

  <!-- Page-specific scripts -->
  <slot name="scripts" />
</body>
</html>
