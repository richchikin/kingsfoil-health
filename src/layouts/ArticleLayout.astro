---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

interface Faq {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  audienceTags: string[];
  difficulty: string;
  publishedDate: Date;
  updatedDate?: Date;
  learningTrack?: string;
  trackOrder?: number;
  relatedArticles?: string[];
  contentCluster?: string;
  keyTakeaways?: string[];
  faqs?: Faq[];
  author?: string;
  authorTitle?: string;
  readingTime?: number;
  seoTitle?: string;
  seoDescription?: string;
  slug: string;
}

const {
  title, description, audienceTags, difficulty,
  publishedDate, updatedDate, learningTrack, trackOrder, relatedArticles,
  contentCluster, keyTakeaways, faqs,
  author = 'Kingsfoil Health Editorial Team', authorTitle,
  readingTime, seoTitle, seoDescription, slug,
} = Astro.props;

// Use seoDescription for meta tags if provided, fall back to the excerpt
// (which is also used as the visible subtitle under the H1).
const metaDescription = seoDescription || description;

const SITE_URL = 'https://kingsfoilhealth.com';
const canonicalPath = `/learn/${slug}`;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;

// Get track info if article belongs to a track
let trackArticles: any[] = [];
let trackName = '';
let trackUrl = '';
if (learningTrack) {
  const allArticles = await getCollection('articles');
  trackArticles = allArticles
    .filter(a => a.data.learningTrack === learningTrack)
    .sort((a, b) => (a.data.trackOrder || 0) - (b.data.trackOrder || 0));
  trackName = learningTrack === 'business-case' ? 'The Business Case' : 'The HR Playbook';
  trackUrl = `/learn/${learningTrack}`;
}

// Resolve related articles to { slug, title }
let relatedResolved: { slug: string; title: string; cluster?: string }[] = [];
if (relatedArticles && relatedArticles.length) {
  const all = await getCollection('articles');
  relatedResolved = relatedArticles
    .map(rs => all.find(a => a.slug === rs))
    .filter(Boolean)
    .map((a: any) => ({ slug: a.slug, title: a.data.title, cluster: a.data.contentCluster }));
}

const isHR = audienceTags.includes('HR');
const badgeClass = isHR ? 'article-badge--hr' : 'article-badge--biz';
const trackClass = isHR ? 'track--hr' : 'track--biz';
const formattedDate = publishedDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const formattedUpdated = updatedDate?.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

// JSON-LD structured data
const breadcrumbItems: { name: string; url: string }[] = [
  { name: 'Home', url: `${SITE_URL}/` },
  { name: 'Learn', url: `${SITE_URL}/learn` },
];
if (learningTrack) {
  breadcrumbItems.push({ name: trackName, url: `${SITE_URL}${trackUrl}` });
}
breadcrumbItems.push({ name: title, url: canonicalUrl });

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  datePublished: publishedDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: {
    '@type': 'Organization',
    name: author,
    url: `${SITE_URL}/about`,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: 'Kingsfoil Health',
    url: SITE_URL,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/images/logo-horizontal.svg`,
    },
  },
  ...(contentCluster && { articleSection: contentCluster }),
  inLanguage: 'en-US',
};

const breadcrumbsForBase = breadcrumbItems.map(b => ({ name: b.name, url: b.url }));

const faqSchema = faqs && faqs.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;

const metaTitle = seoTitle || `${title} — Kingsfoil Health`;
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={canonicalPath}
  ogType="article"
  articlePublishedTime={publishedDate.toISOString()}
  articleModifiedTime={updatedDate?.toISOString()}
  articleAuthor={author}
  articleSection={contentCluster}
  breadcrumbs={breadcrumbsForBase}
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <div class={`article-page ${trackClass}`}>
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/learn">Learn</a>
      {learningTrack && (
        <>
          <span aria-hidden="true">›</span>
          <a href={trackUrl}>{trackName}</a>
        </>
      )}
      <span aria-hidden="true">›</span>
      <span class="breadcrumb-current">{title}</span>
    </nav>

    <article class="article-layout">
      <!-- Article header -->
      <header class="article-header">
        <div class="article-header-meta">
          <span class={`article-badge ${badgeClass}`}>{audienceTags[0]}</span>
          <span class="article-difficulty">{difficulty.charAt(0).toUpperCase() + difficulty.slice(1)}</span>
          {readingTime && <span class="article-difficulty">{readingTime} min read</span>}
        </div>
        <h1>{title}</h1>
        <p class="article-excerpt">{description}</p>
        <div class="article-byline">
          <span class="article-byline-author">By {author}{authorTitle ? `, ${authorTitle}` : ''}</span>
          <span class="article-byline-sep" aria-hidden="true">·</span>
          <time datetime={publishedDate.toISOString().split('T')[0]}>Published {formattedDate}</time>
          {formattedUpdated && (
            <>
              <span class="article-byline-sep" aria-hidden="true">·</span>
              <time datetime={updatedDate!.toISOString().split('T')[0]}>Updated {formattedUpdated}</time>
            </>
          )}
        </div>
      </header>

      <!-- Track progress bar -->
      {learningTrack && trackOrder && (
        <div class="track-context">
          <div class="track-context-progress">
            {trackArticles.map((_, i) => (
              <div class={`track-dot ${i < trackOrder! ? 'track-dot--filled' : ''} ${i === trackOrder! - 1 ? 'track-dot--current' : ''}`} />
            ))}
          </div>
          <div class="track-context-info">
            <span>Article {trackOrder} of {trackArticles.length} in <a href={trackUrl}>{trackName}</a></span>
          </div>
        </div>
      )}

      <!-- Key Takeaways (AEO: answer-engine & featured snippet optimization) -->
      {keyTakeaways && keyTakeaways.length > 0 && (
        <aside class="key-takeaways" aria-labelledby="key-takeaways-heading">
          <h2 id="key-takeaways-heading" class="key-takeaways-heading">Key takeaways</h2>
          <ul>
            {keyTakeaways.map(t => <li>{t}</li>)}
          </ul>
        </aside>
      )}

      <!-- Article body (markdown content) -->
      <div class="article-body">
        <slot />
      </div>

      <!-- FAQ (visible + FAQPage schema rendered in head) -->
      {faqs && faqs.length > 0 && (
        <section class="article-faq" aria-labelledby="faq-heading">
          <h2 id="faq-heading">Frequently asked questions</h2>
          <div class="faq-list">
            {faqs.map(f => (
              <details class="faq-item">
                <summary>{f.question}</summary>
                <div class="faq-answer"><p>{f.answer}</p></div>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- Related articles (cross-cluster linking) -->
      {relatedResolved.length > 0 && (
        <section class="article-related" aria-labelledby="related-heading">
          <h2 id="related-heading">Keep reading</h2>
          <ul class="related-list">
            {relatedResolved.map(r => (
              <li>
                <a href={`/learn/${r.slug}`}>
                  <span class="related-title">{r.title}</span>
                  {r.cluster && <span class="related-cluster">{r.cluster}</span>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Prev / Next navigation (learning track only) -->
      {learningTrack && trackArticles.length > 0 && (
        <nav class="article-nav" aria-label="Article navigation">
          {trackOrder && trackOrder > 1 ? (
            <a href={`/learn/${trackArticles[trackOrder - 2].slug}`} class="article-nav-item article-nav-item--prev">
              <div class="article-nav-label">← Previous</div>
              <div class="article-nav-title">{trackArticles[trackOrder - 2].data.title}</div>
            </a>
          ) : <div />}
          {trackOrder && trackOrder < trackArticles.length ? (
            <a href={`/learn/${trackArticles[trackOrder].slug}`} class="article-nav-item article-nav-item--next">
              <div class="article-nav-label">Next →</div>
              <div class="article-nav-title">{trackArticles[trackOrder].data.title}</div>
            </a>
          ) : <div />}
        </nav>
      )}

      <!-- Bottom CTA -->
      <div class="article-cta">
        <h2>Want to see what this means for your company?</h2>
        <p>We'll walk through your current plan and show you what alternatives might look like. No obligation.</p>
        <a href="/talk-to-us" class="btn-primary">Talk to Us</a>
      </div>
    </article>
  </div>

</BaseLayout>

<style>
/* ============================================
   BREADCRUMB
   ============================================ */
.breadcrumb {
  max-width: 760px;
  margin: 0 auto;
  padding: 24px var(--section-pad-x) 0;
  font-size: 13px;
  color: var(--nero-500);
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.breadcrumb a {
  color: var(--nero-500);
  text-decoration: none;
  transition: color var(--t-fast);
  padding: 8px 4px;
  margin: -8px 0;
}
.breadcrumb a:hover { color: var(--elm-600); }
.breadcrumb span[aria-hidden] { color: var(--nero-300); font-size: 11px; }
.breadcrumb-current {
  color: var(--nero-600);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300px;
}

/* ============================================
   ARTICLE LAYOUT
   ============================================ */
.article-layout {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 var(--section-pad-x) 80px;
}

/* ============================================
   ARTICLE HEADER
   ============================================ */
.article-header {
  padding: 48px 0 40px;
  border-bottom: 1px solid var(--nero-200);
  margin-bottom: 48px;
}
.article-header-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}
.article-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 999px;
}
.article-badge--biz { background: var(--elm-50); color: var(--elm-700); }
.article-badge--hr { background: var(--gold-100); color: var(--gold-800); }
.article-difficulty {
  font-size: 12px;
  font-weight: 500;
  color: var(--nero-500);
}
.article-header h1 {
  font-family: var(--font-display);
  font-size: clamp(32px, 4.5vw, 44px);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}
.article-excerpt {
  font-size: 18px;
  line-height: 1.65;
  color: var(--nero-500);
  margin-bottom: 16px;
}
.article-byline {
  font-size: 13px;
  color: var(--nero-500);
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.article-byline-author { color: var(--nero-500); font-weight: 500; }
.article-byline-sep { color: var(--nero-300); }

/* ============================================
   TRACK CONTEXT BAR
   ============================================ */
.track-context {
  background: var(--warm-linen);
  border: 1px solid var(--nero-100);
  border-radius: 12px;
  padding: 20px 24px;
  margin-bottom: 48px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.track-context-progress {
  display: flex;
  gap: 6px;
}
.track-dot {
  width: 100%;
  height: 4px;
  border-radius: 2px;
  background: var(--nero-200);
  transition: background var(--t-fast);
}
.track--biz .track-dot--filled { background: var(--elm-400); }
.track--hr .track-dot--filled { background: var(--gold-500); }
.track-dot--current {
  box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--elm-400);
}
.track--hr .track-dot--current {
  box-shadow: 0 0 0 2px #fff, 0 0 0 4px var(--gold-500);
}
.track-context-info {
  font-size: 13px;
  color: var(--nero-500);
}
.track-context-info a {
  color: var(--elm-600);
  text-decoration: none;
  font-weight: 600;
}
.track-context-info a:hover { text-decoration: underline; }

/* ============================================
   KEY TAKEAWAYS (AEO box)
   ============================================ */
.key-takeaways {
  background: var(--elm-50);
  border: 1px solid var(--elm-100);
  border-radius: 12px;
  padding: 24px 28px;
  margin-bottom: 40px;
}
.track--hr .key-takeaways {
  background: var(--gold-50);
  border-color: var(--gold-100);
}
.key-takeaways-heading {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  color: var(--elm-800);
  margin: 0 0 12px;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}
.track--hr .key-takeaways-heading { color: var(--gold-800); }
.key-takeaways ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.key-takeaways li {
  position: relative;
  padding-left: 24px;
  margin-bottom: 10px;
  font-size: 15.5px;
  line-height: 1.6;
  color: var(--nero-700);
}
.key-takeaways li:last-child { margin-bottom: 0; }
.key-takeaways li::before {
  content: '→';
  position: absolute;
  left: 0;
  top: 0;
  color: var(--elm-500);
  font-weight: 700;
}
.track--hr .key-takeaways li::before { color: var(--gold-600); }

/* ============================================
   ARTICLE BODY — PROSE STYLES
   ============================================ */
.article-body {
  font-size: 17px;
  line-height: 1.8;
  color: var(--nero-700);
}

.article-body :global(h2) {
  font-family: var(--font-display);
  font-size: clamp(24px, 3vw, 30px);
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: -0.01em;
  color: var(--nero-900);
  margin-top: 56px;
  margin-bottom: 20px;
  scroll-margin-top: 100px;
}
.article-body :global(h3) {
  font-family: var(--font-display);
  font-size: clamp(20px, 2.5vw, 24px);
  font-weight: 700;
  line-height: 1.3;
  color: var(--nero-900);
  margin-top: 44px;
  margin-bottom: 16px;
}
.article-body :global(h4) {
  font-family: var(--font-body);
  font-size: 17px;
  font-weight: 700;
  line-height: 1.4;
  color: var(--nero-800);
  margin-top: 32px;
  margin-bottom: 12px;
}
.article-body :global(p) { margin-bottom: 24px; }
.article-body :global(strong) { font-weight: 600; color: var(--nero-900); }
.article-body :global(em) { font-style: italic; }
.article-body :global(a) {
  color: var(--elm-600);
  text-decoration: underline;
  text-decoration-color: var(--elm-200);
  text-underline-offset: 3px;
  transition: text-decoration-color var(--t-fast);
}
.article-body :global(a:hover) { text-decoration-color: var(--elm-500); }

.article-body :global(ul),
.article-body :global(ol) {
  margin-bottom: 24px;
  padding-left: 24px;
}
.article-body :global(ul) { list-style: none; padding-left: 0; }
.article-body :global(ul > li) {
  position: relative;
  padding-left: 24px;
  margin-bottom: 12px;
}
.article-body :global(ul > li::before) {
  content: '';
  position: absolute;
  left: 0;
  top: 11px;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--elm-400);
}
.article-body :global(ol > li) { margin-bottom: 12px; padding-left: 4px; }
.article-body :global(ol > li::marker) { color: var(--elm-600); font-weight: 600; }
.article-body :global(li > ul),
.article-body :global(li > ol) { margin-top: 8px; margin-bottom: 8px; }

.article-body :global(blockquote) {
  border: 1px solid var(--nero-200);
  padding: 20px 24px;
  margin: 32px 0;
  background: var(--warm-linen);
  border-radius: 12px;
}
.article-body :global(blockquote p) {
  font-size: 16px;
  font-style: italic;
  color: var(--nero-600);
  margin-bottom: 0;
  line-height: 1.7;
}
.article-body :global(blockquote p:not(:last-child)) { margin-bottom: 12px; }

.article-body :global(code) {
  font-family: 'SF Mono', 'Fira Code', 'Fira Mono', monospace;
  font-size: 0.88em;
  background: var(--nero-50);
  border: 1px solid var(--nero-100);
  padding: 2px 6px;
  border-radius: 4px;
  color: var(--nero-700);
}
.article-body :global(hr) {
  border: none;
  height: 1px;
  background: var(--nero-200);
  margin: 48px 0;
}
.article-body :global(img) {
  border-radius: 12px;
  margin: 32px 0;
  box-shadow: 0 4px 16px rgba(38, 35, 36, 0.06);
}
.article-body :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 32px 0;
  font-size: 15px;
  display: block;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.article-body :global(thead) { border-bottom: 2px solid var(--nero-200); }
.article-body :global(th) {
  text-align: left;
  font-weight: 600;
  color: var(--nero-800);
  padding: 12px 16px;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.article-body :global(td) {
  padding: 12px 16px;
  border-bottom: 1px solid var(--nero-100);
  color: var(--nero-600);
}
.article-body :global(tbody tr:hover) { background: var(--warm-linen); }
.article-body :global(> :first-child) { margin-top: 0; }

/* ============================================
   FOOTNOTES (GFM auto-generated)
   ============================================ */
.article-body :global(.footnotes) {
  margin-top: 56px;
  padding-top: 32px;
  border-top: 1px solid var(--nero-200);
  font-size: 14px;
  line-height: 1.7;
  color: var(--nero-500);
}
.article-body :global(.footnotes h2),
.article-body :global(.footnotes .sr-only) {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}
.article-body :global(.footnotes::before) {
  content: 'Sources & notes';
  display: block;
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: var(--nero-800);
  margin-bottom: 16px;
  letter-spacing: -0.01em;
}
.article-body :global(.footnotes ol) {
  padding-left: 24px;
  margin: 0;
}
.article-body :global(.footnotes ol > li) {
  margin-bottom: 10px;
  padding-left: 4px;
}
.article-body :global(.footnotes ol > li::marker) {
  color: var(--elm-600);
  font-weight: 600;
}
.article-body :global(.footnotes p) {
  margin: 0;
  display: inline;
}
.article-body :global(.footnotes a.data-footnote-backref) {
  color: var(--elm-600);
  text-decoration: none;
  margin-left: 4px;
  font-size: 12px;
}
.article-body :global(.footnotes a) {
  color: var(--elm-600);
  text-decoration: underline;
  text-decoration-color: var(--elm-200);
}
.article-body :global(sup a),
.article-body :global(a[data-footnote-ref]) {
  color: var(--elm-600);
  text-decoration: none;
  font-weight: 600;
  padding: 0 1px;
}
.article-body :global(sup a:hover),
.article-body :global(a[data-footnote-ref]:hover) {
  text-decoration: underline;
}

/* ============================================
   FAQ SECTION (AEO)
   ============================================ */
.article-faq {
  margin-top: 64px;
  padding-top: 48px;
  border-top: 1px solid var(--nero-200);
}
.article-faq h2 {
  font-family: var(--font-display);
  font-size: clamp(24px, 3vw, 30px);
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: -0.01em;
  color: var(--nero-900);
  margin-bottom: 24px;
}
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.faq-item {
  border: 1px solid var(--nero-100);
  border-radius: 12px;
  background: #fff;
  transition: border-color var(--t-fast), box-shadow var(--t-fast);
}
.faq-item[open] {
  border-color: var(--elm-200);
  box-shadow: 0 4px 16px rgba(38, 35, 36, 0.04);
}
.faq-item summary {
  cursor: pointer;
  padding: 20px 24px;
  font-size: 17px;
  font-weight: 600;
  color: var(--nero-800);
  list-style: none;
  position: relative;
  padding-right: 56px;
  line-height: 1.4;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
  content: '+';
  position: absolute;
  right: 24px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22px;
  font-weight: 400;
  color: var(--elm-600);
  transition: transform var(--t-med);
  line-height: 1;
}
.faq-item[open] summary::after {
  content: '−';
}
.faq-item summary:hover { color: var(--elm-700); }
.faq-answer {
  padding: 0 24px 20px;
  font-size: 16px;
  line-height: 1.7;
  color: var(--nero-600);
}
.faq-answer p { margin: 0; }

/* ============================================
   RELATED ARTICLES (inline list)
   ============================================ */
.article-related {
  margin-top: 56px;
  padding-top: 40px;
  border-top: 1px solid var(--nero-200);
}
.article-related h2 {
  font-family: var(--font-display);
  font-size: clamp(22px, 3vw, 28px);
  font-weight: 700;
  line-height: 1.25;
  color: var(--nero-900);
