---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reports & Resources — Kingsfoil Health"
  description="Downloadable reports, case studies, and tools to help you evaluate your company\'s health benefits options."
  canonicalPath="/learn/resources"
>

<!-- PAGE HERO -->
<section class="page-hero" aria-label="Page introduction">
  <div class="eyebrow">Resources</div>
  <h1>Reports, case studies, <em>and tools</em></h1>
  <p class="page-hero-sub">Downloadable resources that go deeper than our articles. Built for business leaders and HR professionals evaluating their benefits options.</p>
</section>

<!-- FEATURED RESOURCE (Linen) -->
<!-- CMS: {{#if featured_resource}} -->
<section class="section featured" aria-labelledby="featured-heading">
  <div class="section-inner">
    <div class="featured-layout">
      <div class="featured-content">
        <!-- CMS: {{featured_resource.type}} -->
        <span class="featured-badge">Report</span>
        <!-- CMS: {{featured_resource.title}} -->
        <h2 id="featured-heading">The Small Business Guide to Health Benefits Alternatives</h2>
        <!-- CMS: {{featured_resource.excerpt}} -->
        <p>A comprehensive guide to plan structures beyond fully funded coverage. Written for business leaders with 10 to 250 employees who want to understand their options before the next renewal.</p>
        <div class="featured-highlights">
          <div class="featured-highlight"><div class="featured-highlight-dot" aria-hidden="true"></div><span>Side-by-side comparison of fully funded, level-funded, and self-funded structures</span></div>
          <div class="featured-highlight"><div class="featured-highlight-dot" aria-hidden="true"></div><span>ROI framework with example calculations</span></div>
          <div class="featured-highlight"><div class="featured-highlight-dot" aria-hidden="true"></div><span>Checklist for evaluating your current broker relationship</span></div>
        </div>
        <!-- CMS: gate form — is_gated: true, gate_asset_url: {{resource.asset_url}} -->
        <form class="gate-form" name="resource-download" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="bot-field">
          <label for="gate-email" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">Work email</label>
          <input class="gate-input" type="email" id="gate-email" name="email" placeholder="Your work email" required>
          <button class="gate-submit" type="submit">Get the Guide</button>
        </form>
        <p class="gate-privacy">Free download. We'll send it to your inbox. <a href="/privacy">Privacy Policy</a></p>
      </div>
      <div class="featured-visual" role="img" aria-label="Report cover preview">
        <div class="featured-visual-inner">
          <div class="featured-visual-icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <span class="featured-visual-label">The Small Business Guide to Health Benefits Alternatives</span>
          <span class="featured-visual-format">PDF · 18 pages</span>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- CMS: {{/if}} -->

<!-- RESOURCE GRID (Cream) -->
<section class="section resources" aria-labelledby="resources-heading">
  <div class="section-inner">
    <div class="resources-header">
      <h2 id="resources-heading">All resources</h2>
      <div class="type-filters" role="group" aria-label="Filter resources">
        <button class="type-btn is-active">All</button>
        <button class="type-btn">Reports</button>
        <button class="type-btn">Case Studies</button>
        <button class="type-btn">Tools</button>
      </div>
    </div>
    <div class="resource-grid">
      <!-- CMS: {{#each resources}} -->
      <div class="resource-card">
        <div class="resource-type resource-type--report">Report</div>
        <h3>The Small Business Guide to Health Benefits Alternatives</h3>
        <p>A comprehensive guide to plan structures beyond fully funded coverage, with ROI frameworks and broker evaluation checklists.</p>
        <div class="resource-card-footer">
          <span class="resource-format">PDF · 18 pages</span>
          <a href="#" class="resource-cta" title="Coming soon">Download →</a>
        </div>
      </div>
      <div class="resource-card">
        <div class="resource-type resource-type--case-study">Case Study</div>
        <h3>How a 45-Person Tech Company Saved on Benefits</h3>
        <p>A real-world example of transitioning from fully funded to level-funded coverage, including timeline, employee experience, and financial results.</p>
        <div class="resource-card-footer">
          <span class="resource-format">PDF · 6 pages</span>
          <a href="#" class="resource-cta" title="Coming soon">Download →</a>
        </div>
      </div>
      <div class="resource-card">
        <div class="resource-type resource-type--tool">Tool</div>
        <h3>Benefits Plan Comparison Worksheet</h3>
        <p>A structured worksheet for comparing your current plan against alternative structures. Bring it to your next broker meeting or use it with us.</p>
        <div class="resource-card-footer">
          <span class="resource-format">PDF · 4 pages</span>
          <a href="#" class="resource-cta" title="Coming soon">Download →</a>
        </div>
      </div>
      <div class="resource-card">
        <div class="resource-type resource-type--report">Report</div>
        <h3>Understanding Commission Transparency in Health Insurance</h3>
        <p>What the Consolidated Appropriations Act means for broker compensation, and how to read the disclosure you should be receiving.</p>
        <div class="resource-card-footer">
          <span class="resource-format">PDF · 8 pages</span>
          <a href="#" class="resource-cta" title="Coming soon">Download →</a>
        </div>
      </div>
      <!-- CMS: {{/each}} -->
    </div>
  </div>
</section>

<!-- BOTTOM CTA -->
<section class="bottom-cta" aria-labelledby="cta-heading">
  <h2 id="cta-heading">Ready to put this into practice?</h2>
  <p>Take what you've learned and apply it. A 30-minute conversation to see what's possible for your company.</p>
  <a href="/talk-to-us" class="btn-primary">Talk to Us</a>
</section>

</BaseLayout>

<style>
/* PAGE HERO */
.page-hero{padding:72px var(--section-pad-x) 64px;text-align:center;position:relative;overflow:hidden}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 30% 80%, rgba(252,244,215,0.35) 0%, transparent 50%),radial-gradient(ellipse 40% 50% at 70% 70%, rgba(212,238,234,0.2) 0%, transparent 50%);pointer-events:none}
.page-hero .eyebrow{font-size:12px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--elm-600);position:relative;z-index:1;margin-bottom:16px}
.page-hero h1{font-family:var(--font-display);font-size:clamp(36px,5vw,56px);font-weight:700;line-height:1.08;letter-spacing:-0.03em;max-width:720px;margin:0 auto 20px;position:relative;z-index:1}
.page-hero h1 em{font-style:italic;background:linear-gradient(135deg, var(--elm-600), var(--elm-500));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.page-hero-sub{font-size:clamp(16px,1.6vw,19px);line-height:1.65;color:var(--nero-500);max-width:560px;margin:0 auto;position:relative;z-index:1}

/* FEATURED RESOURCE (Linen) */
.featured{background:var(--warm-linen)}
.featured-layout{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.featured-badge{display:inline-block;font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 14px;border-radius:999px;background:var(--gold-100);color:var(--gold-800);margin-bottom:16px}
.featured-content h2{font-family:var(--font-display);font-size:clamp(26px,3vw,36px);font-weight:700;line-height:1.15;letter-spacing:-0.01em;margin-bottom:16px}
.featured-content p{font-size:16px;line-height:1.7;color:var(--nero-600);margin-bottom:16px}
.featured-highlights{display:flex;flex-direction:column;gap:10px;margin:20px 0 28px}
.featured-highlight{display:flex;align-items:flex-start;gap:10px;font-size:14px;line-height:1.5;color:var(--nero-700)}
.featured-highlight-dot{flex-shrink:0;width:6px;height:6px;border-radius:50%;background:var(--elm-400);margin-top:7px}

/* Gate form inline */
.gate-form{display:flex;gap:12px;flex-wrap:wrap}
.gate-input{font-family:var(--font-body);font-size:14px;padding:12px 16px;border:1px solid var(--nero-200);border-radius:8px;background:#fff;flex:1;min-width:180px;transition:border-color var(--t-fast)}
.gate-input:focus{outline:none;border-color:var(--elm-400);box-shadow:0 0 0 3px rgba(46,149,130,0.12)}
.gate-submit{font-family:var(--font-body);font-size:14px;font-weight:600;background:var(--elm-500);color:#fff;border:none;border-radius:8px;padding:12px 24px;cursor:pointer;transition:background var(--t-fast);white-space:nowrap}
.gate-submit:hover{background:var(--elm-600)}
.gate-privacy{font-size:11px;color:var(--nero-400);margin-top:8px;line-height:1.4}
.gate-privacy a{color:var(--elm-600);text-decoration:underline}

.featured-visual{border-radius:20px;height:360px;overflow:hidden;display:flex;align-items:center;justify-content:center;color:var(--nero-400);font-size:13px;text-align:center;padding:20px;box-shadow:0 16px 48px rgba(38,35,36,0.06);background:linear-gradient(160deg, var(--gold-50) 0%, var(--elm-50) 100%)}
.featured-visual-inner{display:flex;flex-direction:column;align-items:center;gap:12px}
.featured-visual-icon{color:var(--elm-400)}
.featured-visual-label{font-family:var(--font-display);font-size:16px;font-weight:700;color:var(--nero-600);max-width:200px;line-height:1.3}
.featured-visual-format{font-size:12px;color:var(--nero-400)}

/* RESOURCE GRID (Cream) */
.resources{background:var(--warm-cream)}
.resources-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:40px;flex-wrap:wrap;gap:16px}
.resources-header h2{font-family:var(--font-display);font-size:clamp(24px,3vw,32px);font-weight:700;line-height:1.2}
.type-filters{display:flex;gap:8px}
.type-btn{font-family:var(--font-body);font-size:13px;font-weight:600;background:var(--nero-50);color:var(--nero-600);border:1px solid var(--nero-200);border-radius:999px;padding:8px 18px;cursor:pointer;transition:all var(--t-fast)}
.type-btn:hover,.type-btn.is-active{background:var(--elm-50);color:var(--elm-700);border-color:var(--elm-200)}

.resource-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.resource-card{background:#fff;border-radius:16px;padding:36px 32px;border:1px solid var(--nero-100);box-shadow:0 2px 8px rgba(38,35,36,0.04);transition:all var(--t-med);display:flex;flex-direction:column}
.resource-card:hover{border-color:var(--elm-200);box-shadow:0 8px 24px rgba(38,35,36,0.06)}
.resource-type{font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:14px}
.resource-type--report{color:var(--sapphire-600)}
.resource-type--case-study{color:var(--elm-600)}
.resource-type--tool{color:var(--gold-700)}
.resource-card h3{font-family:var(--font-display);font-size:20px;font-weight:700;line-height:1.3;margin-bottom:10px}
.resource-card p{font-size:14px;line-height:1.6;color:var(--nero-600);margin-bottom:20px;flex:1}
.resource-card-footer{display:flex;justify-content:space-between;align-items:center}
.resource-format{font-size:12px;color:var(--nero-400);display:flex;align-items:center;gap:6px}
.resource-cta{font-size:13px;font-weight:600;color:var(--elm-600);text-decoration:none;transition:color var(--t-fast)}
.resource-cta:hover{color:var(--elm-700)}

/* BOTTOM CTA */
.bottom-cta{background:var(--nero-900);color:#fff;text-align:center;padding:var(--section-pad-y) var(--section-pad-x);position:relative;overflow:hidden}
.bottom-cta::before{content:'';position:absolute;bottom:-20%;left:50%;transform:translateX(-50%);width:700px;height:400px;border-radius:50%;background:radial-gradient(ellipse, rgba(225,196,94,0.1) 0%, transparent 60%);pointer-events:none}
.bottom-cta h2{font-family:var(--font-display);font-size:clamp(32px,4vw,48px);font-weight:700;line-height:1.1;letter-spacing:-0.02em;max-width:640px;margin:0 auto 16px;position:relative}
.bottom-cta p{font-size:17px;color:var(--nero-400);margin-bottom:40px;max-width:480px;margin-left:auto;margin-right:auto;position:relative;line-height:1.6}
.btn-primary{display:inline-block;font-family:var(--font-body);font-size:16px;font-weight:600;background:var(--elm-500);color:#fff;border:2px solid transparent;border-radius:8px;padding:14px 32px;cursor:pointer;transition:all var(--t-fast);text-decoration:none}
.btn-primary:hover{background:var(--elm-600);transform:translateY(-1px);box-shadow:0 4px 16px rgba(46,149,130,0.2)}
.bottom-cta .btn-primary{font-size:17px;padding:16px 36px;position:relative}

/* FOOTER */
.footer{background:var(--nero-900);color:var(--nero-400);border-top:1px solid var(--nero-800);padding:64px var(--section-pad-x) 32px;font-size:14px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;max-width:var(--inner-max);margin:0 auto}
.footer-brand{font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--elm-400);margin-bottom:12px}
.footer-tagline{font-style:italic;color:var(--nero-500);margin-bottom:12px;font-size:14px}.footer p{line-height:1.6;max-width:280px}
.footer-col h4{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--nero-500);margin-bottom:16px}
.footer-col a{display:block;color:var(--nero-400);text-decoration:none;margin-bottom:10px;transition:color var(--t-fast)}.footer-col a:hover{color:var(--elm-400)}
.footer-bottom{max-width:var(--inner-max);margin:48px auto 0;padding-top:24px;border-top:1px solid var(--nero-800);font-size:12px;color:var(--nero-600);display:flex;gap:16px;flex-wrap:wrap}
.footer-bottom a{color:var(--nero-500);text-decoration:none;transition:color var(--t-fast)}.footer-bottom a:hover{color:var(--elm-400)}

@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:0.01ms!important;animation-iteration-count:1!important;transition-duration:0.01ms!important}html{scroll-behavior:auto}}
@media(max-width:768px){
  :root{--section-pad-y:80px;--section-pad-x:24px}
  .nav{padding:0 24px;height:64px}.nav-links{display:none}.nav-cta:not(.nav-overlay .nav-cta){display:none}.nav-toggle{display:block}
  .page-hero{padding:48px 24px 56px}
  .featured-layout{grid-template-columns:1fr}.featured-visual{height:200px}
  .gate-form{flex-direction:column}
  .resource-grid{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
}
@media(max-width:420px){:root{--section-pad-x:16px;--section-pad-y:64px}.page-hero{padding:40px 16px 48px}.footer-grid{grid-template-columns:1fr}}
</style>


