---
import BaseLayout from '../../layouts/BaseLayout.astro';

import { getCollection } from 'astro:content';

// Fetch all articles, drop drafts, sort newest first
const allArticles = (await getCollection('articles'))
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());

// Counts per learning track for the track cards
const businessCaseCount = allArticles.filter(a => a.data.learningTrack === 'business-case').length;
const hrPlaybookCount = allArticles.filter(a => a.data.learningTrack === 'hr-playbook').length;

// Group articles by content cluster for the "Browse by topic" section
const CLUSTER_META: Record<string, { title: string; description: string; href: string }> = {
  'Pillar': {
    title: 'Pillar guides',
    description: 'Comprehensive top-level references that anchor each topic.',
    href: '/learn/pillars',
  },
  'Plan Structures': {
    title: 'Plan structures',
    description: 'Fully-insured, level-funded, self-funded — how each works and when to use them.',
    href: '/learn/plan-structures',
  },
  'Plan Types': {
    title: 'Plan types',
    description: 'HMO, PPO, EPO, deductibles, copays — the building blocks of any plan.',
    href: '/learn/plan-types',
  },
  'Premium Costs': {
    title: 'Premium costs',
    description: 'Why premiums keep going up and what you can actually do about it.',
    href: '/learn/premium-costs',
  },
  'Stop-Loss': {
    title: 'Stop-loss insurance',
    description: 'How stop-loss makes self-funded and level-funded plans safe.',
    href: '/learn/stop-loss',
  },
  'HSA & Tax-Advantaged': {
    title: 'HSA & tax-advantaged accounts',
    description: 'HSAs, employer contributions, and the tax efficiency case for HDHPs.',
    href: '/learn/hsa',
  },
  'HRA & Reimbursement': {
    title: 'HRA, ICHRA & QSEHRA',
    description: 'Reimbursement-based benefits — when they fit and how to choose.',
    href: '/learn/hra-ichra',
  },
  'Direct Primary Care': {
    title: 'Direct primary care',
    description: 'How DPC pairs with self-funded plans to cut claims and improve experience.',
    href: '/learn/direct-primary-care',
  },
  'Wellness & EAP': {
    title: 'Wellness & EAP',
    description: 'Employee assistance programs, mental health, and wellness that actually works.',
    href: '/learn/wellness',
  },
  'Broker Transparency': {
    title: 'Broker transparency',
    description: 'How brokers are paid, what to ask, and how to align incentives.',
    href: '/learn/brokers',
  },
  'PEO Comparison': {
    title: 'PEO vs. broker',
    description: 'When a PEO makes sense, when an independent broker wins, and the hidden costs.',
    href: '/learn/peo',
  },
  'ACA Compliance': {
    title: 'ACA compliance',
    description: 'What you actually have to do — and what you don\'t — at every employer size.',
    href: '/learn/aca-compliance',
  },
  'Retention & Culture': {
    title: 'Retention & culture',
    description: 'Health benefits as a retention and recruiting lever.',
    href: '/learn/retention',
  },
  'Utah Local': {
    title: 'Utah employers',
    description: 'Utah-specific carriers, compliance, and market dynamics.',
    href: '/learn/utah',
  },
  'Fundamentals': {
    title: 'Fundamentals',
    description: 'First-time benefits offerings, costs, and the basics of group coverage.',
    href: '/learn/fundamentals',
  },
};

const clusterEntries = Object.entries(CLUSTER_META).map(([cluster, meta]) => {
  const count = allArticles.filter(a => a.data.contentCluster === cluster).length;
  return { cluster, ...meta, count };
}).filter(e => e.count > 0);

// Article display data — flatten to plain objects so we can serialize for client-side filtering
const articlesForDisplay = allArticles.map(a => ({
  slug: a.slug,
  title: a.data.title,
  excerpt: a.data.excerpt,
  audience: a.data.audienceTags?.[0] || 'All',
  audienceTags: a.data.audienceTags || [],
  difficulty: a.data.difficulty,
  cluster: a.data.contentCluster || 'Other',
  readingTime: a.data.readingTime,
  isFeatured: a.data.isFeatured,
  publishedDate: a.data.publishedDate.toISOString(),
}));

// Distinct audience tags + difficulties for filter buttons
const audienceOptions = Array.from(new Set(articlesForDisplay.flatMap(a => a.audienceTags))).sort();
const difficultyOptions = ['beginner', 'intermediate', 'advanced'];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Learn', url: '/learn' },
];

const PAGE_SIZE = 12;
---

<BaseLayout
  title="Learn — Kingsfoil Health"
  description="Practical articles on health insurance, plan structures, claims management, and employee benefits — for business leaders and HR professionals."
  canonicalPath="/learn"
  breadcrumbs={breadcrumbs}
>

<!-- PAGE HERO -->
<section class="page-hero" aria-label="Page introduction">
  <h1>Understand your <em>options</em></h1>
  <p class="page-hero-sub">Practical articles that help business leaders and HR professionals make better decisions about their company's health benefits.</p>
</section>

<!-- LEARNING TRACKS -->
<section class="section tracks" aria-labelledby="tracks-heading">
  <div class="section-inner">
    <div class="tracks-header">
      <h2 id="tracks-heading">Guided learning tracks</h2>
      <p>Two structured paths through benefits modernization, built for the people who make and manage the decision.</p>
    </div>
    <div class="track-cards">
      <a href="/learn/business-case" class="track-card track-card--biz">
        <div class="role">For business leaders</div>
        <h3>The Business Case</h3>
        <p>The financial argument for rethinking your company's health benefits. From rising premiums to ROI modeling.</p>
        <div class="track-meta"><span>{businessCaseCount} articles</span><span>Beginner to Advanced</span></div>
        <span class="track-link">Start the track <span aria-hidden="true">→</span></span>
      </a>
      <a href="/learn/hr-playbook" class="track-card track-card--hr">
        <div class="role">For HR professionals</div>
        <h3>The HR Playbook</h3>
        <p>What benefits modernization looks like operationally. Transitions, templates, and less admin work.</p>
        <div class="track-meta"><span>{hrPlaybookCount} articles</span><span>Beginner to Advanced</span></div>
        <span class="track-link">Start the track <span aria-hidden="true">→</span></span>
      </a>
    </div>
  </div>
</section>

<!-- REPORTS & GUIDES -->
<section class="section reports" aria-labelledby="reports-heading">
  <div class="section-inner">
    <div class="reports-header">
      <h2 id="reports-heading">Reports &amp; guides</h2>
      <p>Free, downloadable resources that go deeper than our articles.</p>
    </div>
    <div class="report-cards">
      <a href="/learn/resources/rate-shock" class="report-card">
        <div class="report-card-visual">
          <div class="report-card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
        </div>
        <div class="report-card-body">
          <span class="report-badge">Free Guide</span>
          <h3>The Rate Shock Survival Guide</h3>
          <p>What's driving your premium increase, the questions to ask your broker, and a framework for evaluating your options.</p>
          <span class="report-link">Get the Guide <span aria-hidden="true">→</span></span>
        </div>
      </a>
      <a href="/learn/resources" class="report-card report-card--browse">
        <div class="report-card-visual report-card-visual--browse">
          <div class="report-card-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
        </div>
        <div class="report-card-body">
          <span class="report-badge report-badge--muted">Resources</span>
          <h3>Browse all resources</h3>
          <p>Reports, tools, and guides to help you evaluate your benefits options.</p>
          <span class="report-link">View Resources <span aria-hidden="true">→</span></span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- BROWSE BY TOPIC -->
<section class="section topics" aria-labelledby="topics-heading">
  <div class="section-inner">
    <div class="topics-header">
      <h2 id="topics-heading">Browse by topic</h2>
      <p>Jump to the area that's most relevant to your decision.</p>
    </div>
    <div class="topic-grid">
      {clusterEntries.map(entry => (
        <a href={entry.href} class="topic-card">
          <div class="topic-card-title">{entry.title}</div>
          <p class="topic-card-desc">{entry.description}</p>
          <div class="topic-card-meta">
            <span class="topic-count">{entry.count} {entry.count === 1 ? 'article' : 'articles'}</span>
            <span class="topic-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ALL ARTICLES -->
<section class="section articles" aria-labelledby="articles-heading">
  <div class="section-inner">
    <div class="articles-header">
      <h2 id="articles-heading">All articles</h2>
      <div class="articles-count" aria-live="polite">
        Showing <span id="visible-count">{Math.min(PAGE_SIZE, articlesForDisplay.length)}</span> of <span id="total-count">{articlesForDisplay.length}</span>
      </div>
    </div>

    <!-- Search + Filters -->
    <div class="filters" role="group" aria-label="Filter articles">
      <div class="filter-group filter-group--search">
        <label for="article-search" class="filter-label">Search:</label>
        <input type="search" id="article-search" class="search-input" placeholder="Search articles..." autocomplete="off">
      </div>
      <div class="filter-group">
        <span class="filter-label">Audience:</span>
        <button class="filter-btn is-active" data-filter="audience" data-value="all" type="button">All</button>
        {audienceOptions.map(tag => (
          <button class="filter-btn" data-filter="audience" data-value={tag} type="button">{tag}</button>
        ))}
      </div>
      <div class="filter-group">
        <span class="filter-label">Difficulty:</span>
        <button class="filter-btn is-active" data-filter="difficulty" data-value="all" type="button">All</button>
        {difficultyOptions.map(d => (
          <button class="filter-btn" data-filter="difficulty" data-value={d} type="button">{d.charAt(0).toUpperCase() + d.slice(1)}</button>
        ))}
      </div>
    </div>

    <!-- Article grid -->
    <div class="article-grid" id="article-grid">
      {articlesForDisplay.map((article, i) => (
        <a
          href={`/learn/${article.slug}`}
          class="article-card"
          data-audience={article.audienceTags.join(',')}
          data-difficulty={article.difficulty}
          data-index={i}
        >
          <div class="article-card-body">
            <div class="article-card-tags">
              <span class={`article-badge ${article.audienceTags.includes('HR') ? 'article-badge--hr' : 'article-badge--biz'}`}>
                {article.audience}
              </span>
              <span class="article-cluster">{article.cluster}</span>
            </div>
            <div class="article-card-title">{article.title}</div>
            <p class="article-card-excerpt">{article.excerpt}</p>
            <div class="article-card-meta">
              <span>{article.difficulty.charAt(0).toUpperCase() + article.difficulty.slice(1)}</span>
              {article.readingTime && <span>· {article.readingTime} min read</span>}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <div class="article-empty" id="article-empty" hidden>
      <p>No articles match the selected filters.</p>
      <button class="filter-btn" type="button" id="reset-filters">Clear filters</button>
    </div>

    <!-- Load more -->
    <div class="article-pagination" id="article-pagination">
      <button class="load-more-btn" type="button" id="load-more">
        Show more articles
      </button>
    </div>
  </div>
</section>

<!-- NEWSLETTER CTA -->
<section class="newsletter" aria-labelledby="newsletter-heading">
  <div class="newsletter-inner">
    <h2 id="newsletter-heading">Get smarter about benefits</h2>
    <p>One email per month. Practical insights on health insurance, cost management, and employee experience. No fluff.</p>
    <form class="newsletter-form" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="bot-field">
      <label for="newsletter-email" class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">Email address</label>
      <input class="newsletter-input" type="email" id="newsletter-email" name="email" placeholder="Your work email" autocomplete="email" required>
      <button class="newsletter-submit" type="submit"><span class="nl-text">Get the Newsletter</span><span class="nl-loading" hidden>Subscribing...</span></button>
    </form>
    <p class="newsletter-success" hidden>You're in. Watch for our next issue.</p>
    <p class="newsletter-privacy">No spam. Unsubscribe anytime.</p>
  </div>
</section>

<!-- Filter + pagination behavior -->
<script is:inline define:vars={{ PAGE_SIZE }}>
(function() {
  const grid = document.getElementById('article-grid');
  const empty = document.getElementById('article-empty');
  const loadMoreBtn = document.getElementById('load-more');
  const pagination = document.getElementById('article-pagination');
  const visibleCountEl = document.getElementById('visible-count');
  const totalCountEl = document.getElementById('total-count');
  const resetBtn = document.getElementById('reset-filters');
  if (!grid) return;

  const cards = Array.from(grid.querySelectorAll('.article-card'));
  const filterButtons = Array.from(document.querySelectorAll('[data-filter]'));

  let activeFilters = { audience: 'all', difficulty: 'all' };
  let visibleLimit = PAGE_SIZE;
  let searchQuery = '';
  const searchInput = document.getElementById('article-search');

  function matchesFilters(card) {
    const audienceTags = (card.dataset.audience || '').split(',');
    const difficulty = card.dataset.difficulty || '';
    const audOk = activeFilters.audience === 'all' || audienceTags.includes(activeFilters.audience);
    const diffOk = activeFilters.difficulty === 'all' || difficulty === activeFilters.difficulty;
    if (!audOk || !diffOk) return false;
    if (searchQuery) {
      const title = (card.querySelector('.article-card-title')?.textContent || '').toLowerCase();
      const excerpt = (card.querySelector('.article-card-excerpt')?.textContent || '').toLowerCase();
      const cluster = (card.querySelector('.article-cluster')?.textContent || '').toLowerCase();
      return title.includes(searchQuery) || excerpt.includes(searchQuery) || cluster.includes(searchQuery);
    }
    return true;
  }

  function render() {
    let matchedCount = 0;
    let shownCount = 0;
    cards.forEach(card => {
      const matches = matchesFilters(card);
      if (matches) {
        matchedCount++;
        if (shownCount < visibleLimit) {
          card.removeAttribute('hidden');
          shownCount++;
        } else {
          card.setAttribute('hidden', '');
        }
      } else {
        card.setAttribute('hidden', '');
      }
    });

    if (matchedCount === 0) {
      empty.removeAttribute('hidden');
      pagination.setAttribute('hidden', '');
    } else {
      empty.setAttribute('hidden', '');
      if (shownCount < matchedCount) {
        pagination.removeAttribute('hidden');
      } else {
        pagination.setAttribute('hidden', '');
      }
    }

    if (visibleCountEl) visibleCountEl.textContent = String(shownCount);
    if (totalCountEl) totalCountEl.textContent = String(matchedCount);
  }

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.dataset.filter;
      const value = btn.dataset.value;
      if (!group || !value) return;
      activeFilters[group] = value;
      // Update active state within the same group
      document.querySelectorAll(`[data-filter="${group}"]`).forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      // Reset pagination on filter change
      visibleLimit = PAGE_SIZE;
      render();
    });
  });

  loadMoreBtn?.addEventListener('click', () => {
    visibleLimit += PAGE_SIZE;
    render();
  });

  resetBtn?.addEventListener('click', () => {
    activeFilters = { audience: 'all', difficulty: 'all' };
    searchQuery = '';
    if (searchInput) searchInput.value = '';
    visibleLimit = PAGE_SIZE;
    document.querySelectorAll('[data-filter]').forEach(b => b.classList.remove('is-active'));
    document.querySelectorAll('[data-value="all"]').forEach(b => b.classList.add('is-active'));
    render();
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    visibleLimit = PAGE_SIZE;
    render();
  });

  render();
})();

// Newsletter form
(function() {
  const form = document.querySelector('.newsletter-form');
  const btn = form?.querySelector('.newsletter-submit');
  const success = document.querySelector('.newsletter-success');
  if (!form || !btn || !success) return;
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    btn.classList.add('is-loading');
    btn.querySelector('.nl-text').hidden = true;
    btn.querySelector('.nl-loading').hidden = false;
    try {
      const data = new FormData(form);
      const resp = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data).toString()
      });
      if (resp.ok) {
        form.hidden = true;
        success.hidden = false;
      } else { throw new Error(); }
    } catch {
      btn.classList.remove('is-loading');
      btn.querySelector('.nl-text').hidden = false;
      btn.querySelector('.nl-loading').hidden = true;
    }
  });
})();
</script>

</BaseLayout>

<style>
/* PAGE HERO */
.page-hero{padding:72px var(--section-pad-x) 64px;text-align:center;position:relative;overflow:hidden}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 30% 80%, rgba(252,244,215,0.35) 0%, transparent 50%),radial-gradient(ellipse 40% 50% at 70% 70%, rgba(212,238,234,0.2) 0%, transparent 50%);pointer-events:none}
.page-hero .eyebrow{color:var(--elm-600);position:relative;z-index:1}
.page-hero h1{font-family:var(--font-display);font-size:clamp(36px,5vw,56px);font-weight:700;line-height:1.08;letter-spacing:-0.03em;max-width:720px;margin:0 auto 20px;position:relative;z-index:1}
.page-hero h1 em{font-style:italic;color:var(--elm-600)}
.page-hero-sub{font-size:clamp(16px,1.6vw,19px);line-height:1.65;color:var(--nero-500);max-width:560px;margin:0 auto;position:relative;z-index:1}

/* LEARNING TRACKS (Linen) */
.tracks{background:var(--warm-linen)}
.tracks-header{text-align:center;max-width:560px;margin:0 auto 48px}
.tracks-header h2{font-family:var(--font-display);font-size:clamp(24px,3vw,34px);font-weight:700;line-height:1.2;margin-bottom:12px}
.tracks-header p{font-size:16px;color:var(--nero-500)}
.track-cards{display:grid;grid-template-columns:1fr 1fr;gap:28px;max-width:920px;margin:0 auto}
.track-card{background:#fff;border-radius:18px;padding:44px 36px;transition:all var(--t-med);position:relative;overflow:hidden;box-shadow:0 2px 8px rgba(38,35,36,0.04);text-decoration:none;display:block;color:inherit}
.track-card:hover{transform:translateY(-4px);box-shadow:0 12px 36px rgba(38,35,36,0.08)}
.track-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px}
.track-card--biz::before{background:linear-gradient(90deg, var(--elm-400), var(--elm-300))}
.track-card--hr::before{background:linear-gradient(90deg, var(--gold-400), var(--gold-300))}
.track-card .role{font-size:12px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:16px}
.track-card--biz .role{color:var(--elm-600)}.track-card--hr .role{color:var(--gold-800)}
.track-card h3{font-family:var(--font-display);font-size:24px;font-weight:700;margin-bottom:12px;line-height:1.25}
.track-card p{font-size:15px;line-height:1.65;color:var(--nero-600);margin-bottom:20px}
.track-meta{font-size:12px;color:var(--nero-500);margin-bottom:20px;display:flex;gap:12px}
.track-link{font-size:14px;font-weight:600;color:var(--sapphire-500);display:inline-flex;align-items:center;gap:6px;transition:gap var(--t-fast)}
.track-card:hover .track-link{gap:10px}

/* REPORTS & GUIDES */
.reports{background:var(--warm-cream)}
.reports-header{text-align:center;max-width:560px;margin:0 auto 40px}
.reports-header h2{font-family:var(--font-display);font-size:clamp(24px,3vw,34px);font-weight:700;line-height:1.2;margin-bottom:12px}
.reports-header p{font-size:16px;color:var(--nero-500)}
.report-cards{display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:920px;margin:0 auto}
.report-card{display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;border:1px solid var(--nero-100);box-shadow:0 2px 8px rgba(38,35,36,0.04);transition:all var(--t-med);text-decoration:none;color:inherit}
.report-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(38,35,36,0.08);border-color:var(--elm-200)}
.report-card-visual{height:100px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg, var(--elm-50), var(--gold-50))}
.report-card-visual--browse{background:linear-gradient(135deg, var(--sapphire-50), var(--elm-50))}
.report-card-icon{color:var(--elm-400)}
.report-card-body{padding:24px 28px 28px;flex:1;display:flex;flex-direction:column}
.report-badge{display:inline-block;font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:4px 12px;border-radius:999px;background:var(--elm-50);color:var(--elm-700);margin-bottom:12px;align-self:flex-start}
.report-badge--muted{background:var(--nero-50);color:var(--nero-500)}
.report-card h3{font-family:var(--font-display);font-size:20px;font-weight:700;line-height:1.3;margin-bottom:8px}
.report-card p{font-size:14px;line-height:1.6;color:var(--nero-600);margin-bottom:16px;flex:1}
.report-link{font-size:14px;font-weight:600;color:var(--elm-600);display:inline-flex;align-items:center;gap:6px;transition:gap var(--t-fast)}
.report-card:hover .report-link{gap:10px}

/* TOPICS (Browse by topic) */
.topics{background:var(--warm-linen)}
.topics-header{text-align:center;max-width:560px;margin:0 auto 40px}
.topics-header h2{font-family:var(--font-display);font-size:clamp(24px,3vw,34px);font-weight:700;line-height:1.2;margin-bottom:12px}
.topics-header p{font-size:16px;color:var(--nero-500)}
.topic-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;max-width:1100px;margin:0 auto}
.topic-card{background:#fff;border:1px solid var(--nero-100);border-radius:14px;padding:24px;text-decoration:none;color:inherit;transition:all var(--t-med);display:flex;flex-direction:column;gap:8px}
.topic-card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(38,35,36,0.06);border-color:var(--elm-200)}
.topic-card-title{font-family:var(--font-display);font-size:18px;font-weight:700;line-height:1.3;color:var(--nero-900)}
.topic-card-desc{font-size:14px;line-height:1.55;color:var(--nero-500);margin:0;flex:1}
.topic-card-meta{display:flex;justify-content:space-between;align-items:center;margin-top:8px}
.topic-count{font-size:12px;font-weight:600;color:var(--elm-700);background:var(--elm-50);padding:3px 10px;border-radius:999px;letter-spacing:0.04em}
.topic-arrow{color:var(--elm-500);font-weight:700;transition:transform var(--t-fast)}
.topic-card:hover .topic-arrow{transform:translateX(2px)}

/* ARTICLE GRID (Cream) */
.articles{background:var(--warm-cream)}
.articles-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:24px;flex-wrap:wrap;gap:16px}
.articles-header h2{font-family:var(--font-display);font-size:clamp(24px,3vw,32px);font-weight:700;line-height:1.2}
.articles-count{font-size:13px;color:var(--nero-500)}
.articles-count span{color:var(--nero-700);font-weight:600}

/* Filters */
.filters{display:flex;flex-direction:column;gap:14px;margin-bottom:32px;padding:20px;background:#fff;border:1px solid var(--nero-100);border-radius:14px}
.filter-group{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.filter-label{font-size:12px;font-weight:600;color:var(--nero-500);text-transform:uppercase;letter-spacing:0.06em;margin-right:4px}
.filter-group--search{flex:1;min-width:200px}
.search-input{font-family:var(--font-body);font-size:14px;width:100%;padding:10px 16px;min-height:44px;border:1px solid var(--nero-200);border-radius:10px;background:var(--warm-cream);transition:border-color var(--t-fast)}
.search-input:focus{outline:none;border-color:var(--elm-400);box-shadow:0 0 0 3px rgba(46,149,130,0.12)}
.search-input::placeholder{color:var(--nero-500)}
.filter-btn{font-family:var(--font-body);font-size:13px;font-weight:600;background:var(--nero-50);color:var(--nero-600);border:1px solid var(--nero-200);border-radius:999px;padding:10px 16px;min-height:44px;cursor:pointer;transition:all var(--t-fast)}
.filter-btn:hover{background:var(--elm-50);color:var(--elm-700);border-color:var(--elm-200)}
.filter-btn.is-active{background:var(--elm-500);color:#fff;border-color:var(--elm-500)}

.article-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px}
.article-card{background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 2px 8px rgba(38,35,36,0.04);border:1px solid var(--nero-100);transition:all var(--t-med);text-decoration:none;display:flex;flex-direction:column;color:inherit}
.article-card[hidden]{display:none}
.article-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(38,35,36,0.08);border-color:var(--elm-200)}
.article-card-body{padding:22px;display:flex;flex-direction:column;gap:10px;flex:1}
.article-card-tags{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.article-badge{display:inline-block;font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:4px 10px;border-radius:999px}
.article-badge--biz{background:var(--elm-50);color:var(--elm-700)}
.article-badge--hr{background:var(--gold-100);color:var(--gold-800)}
.article-cluster{font-size:11px;color:var(--nero-500);font-weight:500}
.article-card-title{font-family:var(--font-display);font-size:17px;font-weight:700;line-height:1.35;color:var(--nero-900)}
.article-card-excerpt{font-size:13px;line-height:1.55;color:var(--nero-500);margin:0;flex:1;
  display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.article-card-meta{font-size:12px;color:var(--nero-500);display:flex;gap:8px}

/* Empty state */
.article-empty{text-align:center;padding:60px 20px;background:#fff;border:1px solid var(--nero-100);border-radius:14px}
.article-empty p{font-size:15px;color:var(--nero-500);margin-bottom:16px}
.article-empty[hidden]{display:none}

/* Pagination */
.article-pagination{text-align:center;margin-top:40px}
.article-pagination[hidden]{display:none}
.load-more-btn{font-family:var(--font-body);font-size:14px;font-weight:600;background:#fff;color:var(--elm-700);border:1px solid var(--elm-200);border-radius:10px;padding:14px 32px;cursor:pointer;transition:all var(--t-fast)}
.load-more-btn:hover{background:var(--elm-50);border-color:var(--elm-400)}

/* NEWSLETTER CTA (Brand dark) */
.newsletter{background:linear-gradient(135deg, var(--elm-700), var(--elm-600));color:#fff;position:relative;overflow:hidden;padding:80px var(--section-pad-x)}
.newsletter::before{content:'';position:absolute;top:-20%;right:-10%;width:400px;height:400px;border-radius:50%;background:radial-gradient(ellipse, rgba(225,196,94,0.08) 0%, transparent 60%);pointer-events:none}
.newsletter-inner{max-width:640px;margin:0 auto;text-align:center;position:relative;z-index:1}
.newsletter-inner h2{font-family:var(--font-display);font-size:clamp(24px,3vw,34px);font-weight:700;line-height:1.2;margin-bottom:12px}
.newsletter-inner p{font-size:16px;color:var(--elm-100);margin-bottom:32px;line-height:1.6}
.newsletter-form{display:flex;gap:12px;max-width:480px;margin:0 auto}
.newsletter-input{flex:1;font-family:var(--font-body);font-size:15px;padding:14px 18px;border:2px solid rgba(255,255,255,0.15);border-radius:10px;background:rgba(255,255,255,0.08);color:#fff;transition:all var(--t-fast)}
.newsletter-input::placeholder{color:rgba(255,255,255,0.4)}
.newsletter-input:focus{outline:none;border-color:var(--gold-400);background:rgba(255,255,255,0.12)}
.newsletter-submit{font-family:var(--font-body);font-size:15px;font-weight:600;background:var(--gold-500);color:var(--nero-900);border:none;border-radius:10px;padding:14px 28px;cursor:pointer;transition:all var(--t-fast);white-space:nowrap}
.newsletter-submit:hover{background:var(--gold-400)}
.newsletter-submit.is-loading{opacity:0.7;pointer-events:none}
.newsletter-success{font-size:15px;color:var(--elm-300);font-weight:600;margin-top:12px}
.newsletter-privacy{font-size:12px;color:var(--elm-200);margin-top:12px;opacity:0.7}

@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:0.01ms!important;animation-iteration-count:1!important;transition-duration:0.01ms!important}html{scroll-behavior:auto}}
@media(max-width:768px){
  :root{--section-pad-y:80px;--section-pad-x:24px}
  .page-hero{padding:48px 24px 56px}
  .track-cards{grid-template-columns:1fr}
  .report-cards{grid-template-columns:1fr}
  .topic-grid{grid-template-columns:1fr}
  .article-grid{grid-template-columns:1fr}
  .newsletter-form{flex-direction:column}
  .articles-header{flex-direction:column;align-items:flex-start}
}
@media(max-width:420px){:root{--section-pad-x:16px;--section-pad-y:64px}.page-hero{padding:40px 16px 48px}}
</style>


</BaseLayout>
