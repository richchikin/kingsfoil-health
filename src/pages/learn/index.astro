---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Learn — Kingsfoil Health"
  description="Practical articles that help business leaders and HR professionals understand their health benefits options."
  canonicalPath="/learn"
>

<!-- PAGE HERO -->
<section class="page-hero" aria-label="Page introduction">
  <div class="eyebrow">Learn</div>
  <h1>Understand your <em>options</em></h1>
  <p class="page-hero-sub">Practical articles that help business leaders and HR professionals make better decisions about their company's health benefits.</p>
</section>

<!-- LEARNING TRACKS (Linen) -->
<section class="section tracks" aria-labelledby="tracks-heading">
  <div class="section-inner">
    <div class="tracks-header">
      <h2 id="tracks-heading">Guided learning tracks</h2>
      <p>Two structured paths through benefits modernization, built for the people who make and manage the decision.</p>
    </div>
    <div class="track-cards">
      <a href="/learn/business-case" class="track-card track-card--biz">
        <div class="role">For business leaders</div>
        <h3>The Business Case</h3>
        <p>The financial argument for rethinking your company's health benefits. From rising premiums to ROI modeling.</p>
        <div class="track-meta"><span>8 articles</span><span>~60 min</span><span>Beginner to Advanced</span></div>
        <span class="track-link">Start the track <span aria-hidden="true">→</span></span>
      </a>
      <a href="/learn/hr-playbook" class="track-card track-card--hr">
        <div class="role">For HR professionals</div>
        <h3>The HR Playbook</h3>
        <p>What benefits modernization looks like operationally. Transitions, templates, and less admin work.</p>
        <div class="track-meta"><span>7 articles</span><span>~55 min</span><span>Beginner to Advanced</span></div>
        <span class="track-link">Start the track <span aria-hidden="true">→</span></span>
      </a>
    </div>
  </div>
</section>

<!-- ALL ARTICLES (Cream) -->
<section class="section articles" aria-labelledby="articles-heading">
  <div class="section-inner">
    <div class="articles-header">
      <h2 id="articles-heading">All articles</h2>
      <div class="filters" role="group" aria-label="Filter articles">
        <button class="filter-btn is-active">All</button>
        <button class="filter-btn">Business Leaders</button>
        <button class="filter-btn">HR Playbook</button>
        <button class="filter-btn">Beginner</button>
        <button class="filter-btn">Intermediate</button>
        <button class="filter-btn">Advanced</button>
      </div>
    </div>
    <div class="article-grid">
      <!-- CMS: {{#each articles}} -->
      <a href="/learn/business-case/why-premiums-keep-climbing" class="article-card">
        <div class="article-card-image">
          <img src="/images/article-premiums.jpg" alt="Financial documents and calculator" width="600" height="400" loading="lazy">
        </div>
        <div class="article-card-body">
          <span class="article-badge article-badge--biz">Business Leaders</span>
          <div class="article-card-title">Why Your Health Insurance Premiums Keep Climbing</div>
          <div class="article-card-meta">Beginner · 5 min read</div>
        </div>
      </a>
      <a href="/learn/business-case/fully-funded-alternatives" class="article-card">
        <div class="article-card-image">
          <img src="/images/article-alternatives.jpg" alt="Business planning with laptop and documents" width="600" height="400" loading="lazy">
        </div>
        <div class="article-card-body">
          <span class="article-badge article-badge--biz">Business Leaders</span>
          <div class="article-card-title">What Are the Alternatives to Fully Funded Plans?</div>
          <div class="article-card-meta">Beginner · 6 min read</div>
        </div>
      </a>
      <a href="/learn/hr-playbook/why-benefits-feel-hard" class="article-card">
        <div class="article-card-image">
          <img src="/images/article-hr-challenges.jpg" alt="Professional woman in modern office" width="600" height="400" loading="lazy">
        </div>
        <div class="article-card-body">
          <span class="article-badge article-badge--hr">HR Playbook</span>
          <div class="article-card-title">Why Benefits Feel So Hard (It's Not You)</div>
          <div class="article-card-meta">Beginner · 4 min read</div>
        </div>
      </a>
      <a href="/learn/business-case/claims-data" class="article-card">
        <div class="article-card-image">
          <img src="/images/article-claims-data.jpg" alt="Charts and data visualizations" width="600" height="400" loading="lazy">
        </div>
        <div class="article-card-body">
          <span class="article-badge article-badge--biz">Business Leaders</span>
          <div class="article-card-title">Claims Data: What You Should Be Seeing (And Aren't)</div>
          <div class="article-card-meta">Intermediate · 5 min read</div>
        </div>
      </a>
      <a href="/learn/hr-playbook/concierge-vs-call-center" class="article-card">
        <div class="article-card-image">
          <img src="/images/article-concierge.jpg" alt="Healthcare professional at laptop with stethoscope" width="600" height="400" loading="lazy">
        </div>
        <div class="article-card-body">
          <span class="article-badge article-badge--hr">HR Playbook</span>
          <div class="article-card-title">Concierge vs. Call Center: What Your Employees Actually Experience</div>
          <div class="article-card-meta">Intermediate · 5 min read</div>
        </div>
      </a>
      <a href="/learn/business-case/roi-modeling" class="article-card">
        <div class="article-card-image">
          <img src="/images/article-roi.jpg" alt="Financial charts and market data" width="600" height="400" loading="lazy">
        </div>
        <div class="article-card-body">
          <span class="article-badge article-badge--biz">Business Leaders</span>
          <div class="article-card-title">How to Model the ROI of Switching Plan Structures</div>
          <div class="article-card-meta">Advanced · 7 min read</div>
        </div>
      </a>
      <!-- CMS: {{/each}} -->
    </div>
  </div>
</section>

<!-- NEWSLETTER CTA -->
<section class="newsletter" aria-labelledby="newsletter-heading">
  <div class="newsletter-inner">
    <h2 id="newsletter-heading">Get smarter about benefits</h2>
    <p>One email per month. Practical insights on health insurance, cost management, and employee experience. No fluff.</p>
    <form class="newsletter-form" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field">
      <input type="hidden" name="bot-field">
      <label for="newsletter-email" class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">Email address</label>
      <input class="newsletter-input" type="email" id="newsletter-email" name="email" placeholder="Your work email" required>
      <button class="newsletter-submit" type="submit">Get the Newsletter</button>
    </form>
    <p class="newsletter-privacy">No spam. Unsubscribe anytime.</p>
  </div>
</section>

</BaseLayout>

<style>
/* PAGE HERO */
.page-hero{padding:72px var(--section-pad-x) 64px;text-align:center;position:relative;overflow:hidden}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 30% 80%, rgba(252,244,215,0.35) 0%, transparent 50%),radial-gradient(ellipse 40% 50% at 70% 70%, rgba(212,238,234,0.2) 0%, transparent 50%);pointer-events:none}
.page-hero .eyebrow{color:var(--elm-600);position:relative;z-index:1}
.page-hero h1{font-family:var(--font-display);font-size:clamp(36px,5vw,56px);font-weight:700;line-height:1.08;letter-spacing:-0.03em;max-width:720px;margin:0 auto 20px;position:relative;z-index:1}
.page-hero h1 em{font-style:italic;background:linear-gradient(135deg, var(--elm-600), var(--elm-500));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.page-hero-sub{font-size:clamp(16px,1.6vw,19px);line-height:1.65;color:var(--nero-500);max-width:560px;margin:0 auto;position:relative;z-index:1}

/* LEARNING TRACKS (Linen) */
.tracks{background:var(--warm-linen)}
.tracks-header{text-align:center;max-width:560px;margin:0 auto 48px}
.tracks-header h2{font-family:var(--font-display);font-size:clamp(24px,3vw,34px);font-weight:700;line-height:1.2;margin-bottom:12px}
.tracks-header p{font-size:16px;color:var(--nero-500)}
.track-cards{display:grid;grid-template-columns:1fr 1fr;gap:28px;max-width:920px;margin:0 auto}
.track-card{background:#fff;border-radius:18px;padding:44px 36px;transition:all var(--t-med);position:relative;overflow:hidden;box-shadow:0 2px 8px rgba(38,35,36,0.04);text-decoration:none;display:block;color:inherit}
.track-card:hover{transform:translateY(-4px);box-shadow:0 12px 36px rgba(38,35,36,0.08)}
.track-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px}
.track-card--biz::before{background:linear-gradient(90deg, var(--elm-400), var(--elm-300))}
.track-card--hr::before{background:linear-gradient(90deg, var(--gold-400), var(--gold-300))}
.track-card .role{font-size:12px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:16px}
.track-card--biz .role{color:var(--elm-600)}.track-card--hr .role{color:var(--gold-700)}
.track-card h3{font-family:var(--font-display);font-size:24px;font-weight:700;margin-bottom:12px;line-height:1.25}
.track-card p{font-size:15px;line-height:1.65;color:var(--nero-600);margin-bottom:20px}
.track-meta{font-size:12px;color:var(--nero-400);margin-bottom:20px;display:flex;gap:12px}
.track-link{font-size:14px;font-weight:600;color:var(--sapphire-500);display:inline-flex;align-items:center;gap:6px;transition:gap var(--t-fast)}
.track-card:hover .track-link{gap:10px}

/* ARTICLE GRID (Cream) */
.articles{background:var(--warm-cream)}
.articles-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:40px;flex-wrap:wrap;gap:16px}
.articles-header h2{font-family:var(--font-display);font-size:clamp(24px,3vw,32px);font-weight:700;line-height:1.2}
/* Filters */
.filters{display:flex;gap:8px;flex-wrap:wrap}
.filter-btn{font-family:var(--font-body);font-size:13px;font-weight:600;background:var(--nero-50);color:var(--nero-600);border:1px solid var(--nero-200);border-radius:999px;padding:8px 18px;cursor:pointer;transition:all var(--t-fast)}
.filter-btn:hover,.filter-btn.is-active{background:var(--elm-50);color:var(--elm-700);border-color:var(--elm-200)}

.article-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.article-card{background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 2px 8px rgba(38,35,36,0.04);border:1px solid var(--nero-100);transition:all var(--t-med);text-decoration:none;display:block;color:inherit}
.article-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(38,35,36,0.08)}
.article-card-image{height:140px;overflow:hidden}
.article-card-image img{width:100%;height:100%;object-fit:cover;display:block}
.article-card:nth-child(3n+1) .article-card-image{background:var(--elm-50)}
.article-card:nth-child(3n+2) .article-card-image{background:var(--sapphire-50)}
.article-card:nth-child(3n+3) .article-card-image{background:var(--gold-50)}
.article-card-body{padding:24px}
.article-badge{display:inline-block;font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:4px 12px;border-radius:999px;margin-bottom:12px}
.article-badge--biz{background:var(--elm-50);color:var(--elm-700)}
.article-badge--hr{background:var(--gold-100);color:var(--gold-800)}
.article-card-title{font-family:var(--font-display);font-size:17px;font-weight:700;line-height:1.35;margin-bottom:8px}
.article-card-meta{font-size:12px;color:var(--nero-400)}

/* NEWSLETTER CTA (Brand dark) */
.newsletter{background:linear-gradient(135deg, var(--elm-700), var(--elm-600));color:#fff;position:relative;overflow:hidden;padding:80px var(--section-pad-x)}
.newsletter::before{content:'';position:absolute;top:-20%;right:-10%;width:400px;height:400px;border-radius:50%;background:radial-gradient(ellipse, rgba(225,196,94,0.08) 0%, transparent 60%);pointer-events:none}
.newsletter-inner{max-width:640px;margin:0 auto;text-align:center;position:relative;z-index:1}
.newsletter-inner h2{font-family:var(--font-display);font-size:clamp(24px,3vw,34px);font-weight:700;line-height:1.2;margin-bottom:12px}
.newsletter-inner p{font-size:16px;color:var(--elm-100);margin-bottom:32px;line-height:1.6}
.newsletter-form{display:flex;gap:12px;max-width:480px;margin:0 auto}
.newsletter-input{flex:1;font-family:var(--font-body);font-size:15px;padding:14px 18px;border:2px solid rgba(255,255,255,0.15);border-radius:10px;background:rgba(255,255,255,0.08);color:#fff;transition:all var(--t-fast)}
.newsletter-input::placeholder{color:rgba(255,255,255,0.4)}
.newsletter-input:focus{outline:none;border-color:var(--gold-400);background:rgba(255,255,255,0.12)}
.newsletter-submit{font-family:var(--font-body);font-size:15px;font-weight:600;background:var(--gold-500);color:var(--nero-900);border:none;border-radius:10px;padding:14px 28px;cursor:pointer;transition:all var(--t-fast);white-space:nowrap}
.newsletter-submit:hover{background:var(--gold-400)}
.newsletter-privacy{font-size:12px;color:var(--elm-200);margin-top:12px;opacity:0.7}

/* FOOTER */
.footer{background:var(--nero-900);color:var(--nero-400);border-top:1px solid var(--nero-800);padding:64px var(--section-pad-x) 32px;font-size:14px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;max-width:var(--inner-max);margin:0 auto}
.footer-brand{font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--elm-400);margin-bottom:12px}
.footer-tagline{font-style:italic;color:var(--nero-500);margin-bottom:12px;font-size:14px}
.footer p{line-height:1.6;max-width:280px}
.footer-col h4{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--nero-500);margin-bottom:16px}
.footer-col a{display:block;color:var(--nero-400);text-decoration:none;margin-bottom:10px;transition:color var(--t-fast)}.footer-col a:hover{color:var(--elm-400)}
.footer-bottom{max-width:var(--inner-max);margin:48px auto 0;padding-top:24px;border-top:1px solid var(--nero-800);font-size:12px;color:var(--nero-600);display:flex;gap:16px;flex-wrap:wrap}
.footer-bottom a{color:var(--nero-500);text-decoration:none;transition:color var(--t-fast)}.footer-bottom a:hover{color:var(--elm-400)}

@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:0.01ms!important;animation-iteration-count:1!important;transition-duration:0.01ms!important}html{scroll-behavior:auto}}
@media(max-width:768px){
  :root{--section-pad-y:80px;--section-pad-x:24px}
  .nav{padding:0 24px;height:64px}.nav-links{display:none}.nav-cta:not(.nav-overlay .nav-cta){display:none}.nav-toggle{display:block}
  .page-hero{padding:48px 24px 56px}
  .track-cards{grid-template-columns:1fr}
  .article-grid{grid-template-columns:1fr}
  .newsletter-form{flex-direction:column}
  .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
}
@media(max-width:420px){:root{--section-pad-x:16px;--section-pad-y:64px}.page-hero{padding:40px 16px 48px}.footer-grid{grid-template-columns:1fr}}
</style>


