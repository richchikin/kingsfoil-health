---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service — Kingsfoil Health"
  description="Terms and conditions for using the Kingsfoil Health website."
  canonicalPath="/terms"
>

<!-- PAGE HERO -->
<section class="page-hero" aria-label="Page introduction">
  <div class="eyebrow">Terms of Service</div>
  <h1>Terms of <em>service</em></h1>
  <p class="page-hero-sub">Please read these terms carefully before using our website.</p>
</section>

<!-- PROSE CONTENT -->
<section class="section prose-section" aria-label="Terms of service content">
  <div class="section-inner">
    <div class="prose">
      <p class="last-updated">Last updated: March 25, 2026</p>

      <h2>Acceptance of Terms</h2>
      <p>By accessing and using the Kingsfoil Health website (kingsfoilhealth.com), operated by Resilience Stack, LLC ("we," "us," or "our"), you accept and agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website.</p>

      <h2>Use of the Site</h2>
      <p>You may use our website for lawful purposes only. You agree not to:</p>
      <ul>
        <li>Use the site in any way that violates applicable federal, state, or local laws</li>
        <li>Attempt to gain unauthorized access to any part of the site or its related systems</li>
        <li>Use the site to transmit any harmful, threatening, or objectionable material</li>
        <li>Interfere with or disrupt the operation of the site</li>
        <li>Use automated systems (bots, scrapers) to access the site without our prior written consent</li>
