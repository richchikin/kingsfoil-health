---
import BaseLayout from '@layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import partnershipMeeting from '@assets/images/partnership-meeting.jpg';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Partners', url: '/partners' },
];
---

<BaseLayout
  title="Partners — Kingsfoil Health"
  description="Kingsfoil Health partners with industry-leading providers — HealthEZ, Thatch, Healthee, 401Go, and more — to deliver modern benefits infrastructure for your company."
  canonicalPath="/partners"
  breadcrumbs={breadcrumbs}
>

<!-- PAGE HERO -->
<section class="page-hero" aria-label="Page introduction">
  <h1>Built with the <em>right partners</em></h1>
  <p class="page-hero-sub">We partner with industry-leading providers to deliver modern benefits infrastructure. The outcomes matter more than the names, but here's who we work with and why.</p>
</section>

<!-- PARTNER GRID (Linen) -->
<section class="section partner-grid-section" aria-labelledby="partners-heading">
  <div class="section-inner">
    <h2 id="partners-heading" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">Our partners</h2>
    <div class="partner-grid">
      <div class="partner-card">
        <div class="partner-card-brand">
          <img src="/images/logo-healthez.png" alt="HealthEZ logo" class="partner-logo-img" width="200" height="60" loading="lazy">
          <div class="partner-role">Third-Party Administrator</div>
        </div>
        <p>HealthEZ serves as our TPA for level-funded and self-funded plans. They handle claims processing, plan administration, and compliance so your benefits run smoothly behind the scenes. Their transparent reporting gives you visibility into where every dollar goes.</p>
      </div>
      <div class="partner-card">
        <div class="partner-card-brand">
          <img src="/images/logo-thatch.jpg" alt="Thatch logo" class="partner-logo-img" width="200" height="60" loading="lazy">
          <div class="partner-role">ICHRA Platform</div>
        </div>
        <p>Thatch powers our Individual Coverage HRA (ICHRA) offerings. Their platform makes it simple for employers to provide tax-advantaged health benefits while giving employees the freedom to choose their own coverage. Modern, flexible, and built for today's workforce.</p>
      </div>
      <div class="partner-card">
        <div class="partner-card-brand">
          <img src="/images/logo-401go.jpg" alt="401Go logo" class="partner-logo-img" width="200" height="60" loading="lazy">
          <div class="partner-role">Retirement Benefits</div>
        </div>
        <p>401Go integrates retirement benefits alongside your health plan. A complete benefits package helps you attract and retain talent. Their platform is designed specifically for small and mid-size businesses, making 401(k) administration straightforward.</p>
      </div>
      <div class="partner-card">
        <div class="partner-card-brand">
          <img src="/images/logo-row-partners.png" alt="Row Partners logo" class="partner-logo-img" width="200" height="60" loading="lazy">
          <div class="partner-role">Employee Health Concierge</div>
        </div>
        <p>Row Partners provides concierge-level health navigation for your employees. Instead of a call center, your team gets a real person who helps them find the right provider, understand their benefits, and navigate the healthcare system with confidence.</p>
      </div>
      <div class="partner-card">
        <div class="partner-card-brand">
          <img src="/images/logo-healthee.svg" alt="Healthee logo" class="partner-logo-img" width="200" height="60" loading="lazy">
          <div class="partner-role">AI Benefits Navigation</div>
        </div>
        <p>Healthee gives your employees an AI-powered benefits assistant available anytime. They can look up coverage details, find in-network providers, and get answers to benefits questions instantly — reducing the load on your HR team.</p>
      </div>
      <div class="partner-card">
        <div class="partner-card-brand">
          <img src="/images/logo-outsail.png" alt="Outsail logo" class="partner-logo-img" width="200" height="60" loading="lazy">
          <div class="partner-role">Broker Intelligence</div>
        </div>
        <p>Outsail provides the plan comparison and analytics tooling that helps us evaluate options objectively. Their platform ensures we're looking at the full market when building your benefits strategy, not just the plans that are easiest to quote.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW WE CHOOSE (Cream) -->
<section class="section choosing" aria-labelledby="choosing-heading">
  <div class="section-inner">
    <div class="choosing-layout">
      <div class="choosing-content">
        <h2 id="choosing-heading">How we choose partners</h2>
        <p>We don't partner with every vendor that comes knocking. Every company in our ecosystem has been vetted against a simple standard: does this make things better for the businesses and people we serve?</p>
        <p>We evaluate partners on transparency, service quality, technology, and alignment with our values. If a partner can't demonstrate measurable benefit to our clients, they don't make the cut — regardless of incentives or industry relationships.</p>
        <p>This isn't a static list. We continuously evaluate our partnerships and aren't afraid to make changes when something better comes along for our clients.</p>
      </div>
      <div class="choosing-visual">
        <Image src={partnershipMeeting} alt="Team collaborating around a whiteboard in a bright office" width={800} height={600} loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- BOTTOM CTA -->
<section class="bottom-cta" aria-labelledby="cta-heading">
  <h2 id="cta-heading">Let's talk about what's possible</h2>
  <p>A 30-minute conversation. No jargon, no pressure. Just a clear look at your options.</p>
  <a href="/talk-to-us" class="btn-primary">Talk to Us</a>
</section>

</BaseLayout>

<style>
/* PAGE HERO */
.page-hero{padding:72px var(--section-pad-x) 64px;text-align:center;position:relative;overflow:hidden}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 30% 80%, rgba(252,244,215,0.35) 0%, transparent 50%),radial-gradient(ellipse 40% 50% at 70% 70%, rgba(212,238,234,0.2) 0%, transparent 50%);pointer-events:none}
.page-hero .eyebrow{color:var(--elm-600);position:relative;z-index:1}
.page-hero h1{font-family:var(--font-display);font-size:clamp(36px,5vw,60px);font-weight:700;line-height:1.08;letter-spacing:-0.03em;max-width:720px;margin:0 auto 20px;position:relative;z-index:1}
.page-hero h1 em{font-style:italic;color:var(--elm-600)}
.page-hero-sub{font-size:clamp(16px,1.6vw,19px);line-height:1.65;color:var(--nero-500);max-width:560px;margin:0 auto;position:relative;z-index:1}

/* PARTNER GRID (Linen) */
.partner-grid-section{background:var(--warm-linen)}
.partner-grid{display:flex;flex-direction:column;gap:16px}
.partner-card{background:#fff;border-radius:14px;padding:28px 32px;border:1px solid var(--nero-100);box-shadow:0 2px 8px rgba(38,35,36,0.04);transition:all var(--t-med);display:grid;grid-template-columns:160px 1fr;gap:28px;align-items:center}
.partner-card:hover{border-color:var(--elm-200);box-shadow:0 8px 24px rgba(38,35,36,0.06)}
.partner-card-brand{display:flex;flex-direction:column;align-items:flex-start;gap:8px}
.partner-logo-img{height:36px;width:auto;object-fit:contain;display:block}
.partner-role{font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--elm-600)}
.partner-card p{font-size:15px;line-height:1.7;color:var(--nero-600)}

/* HOW WE CHOOSE (Cream) */
.choosing{background:var(--warm-cream)}
.choosing-layout{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.choosing-content .eyebrow{margin-bottom:8px}
.choosing-content h2{font-family:var(--font-display);font-size:clamp(28px,3.5vw,38px);font-weight:700;line-height:1.15;letter-spacing:-0.02em;margin-bottom:24px}
.choosing-content p{font-size:17px;line-height:1.7;color:var(--nero-600);margin-bottom:20px}
.choosing-content p:last-of-type{margin-bottom:0}
.choosing-visual{border-radius:20px;height:360px;overflow:hidden;box-shadow:0 16px 48px rgba(38,35,36,0.06)}
.choosing-visual img{width:100%;height:100%;object-fit:cover;display:block}

/* BOTTOM CTA */
.bottom-cta{background:var(--nero-900);color:#fff;text-align:center;padding:var(--section-pad-y) var(--section-pad-x);position:relative;overflow:hidden}
.bottom-cta::before{content:'';position:absolute;bottom:-20%;left:50%;transform:translateX(-50%);width:700px;height:400px;border-radius:50%;background:radial-gradient(ellipse, rgba(225,196,94,0.1) 0%, transparent 60%);pointer-events:none}
.bottom-cta::after{content:'';position:absolute;top:-10%;left:30%;width:400px;height:300px;border-radius:50%;background:radial-gradient(ellipse, rgba(46,149,130,0.06) 0%, transparent 60%);pointer-events:none}
.bottom-cta h2{font-family:var(--font-display);font-size:clamp(32px,4vw,48px);font-weight:700;line-height:1.1;letter-spacing:-0.02em;max-width:640px;margin:0 auto 16px;position:relative}
.bottom-cta p{font-size:17px;color:var(--nero-500);margin-bottom:40px;max-width:480px;margin-left:auto;margin-right:auto;position:relative;line-height:1.6}
.btn-primary{display:inline-block;font-family:var(--font-body);font-size:16px;font-weight:600;background:var(--elm-500);color:#fff;border:2px solid transparent;border-radius:8px;padding:14px 32px;cursor:pointer;transition:all var(--t-fast);text-decoration:none}
.btn-primary:hover{background:var(--elm-600);transform:translateY(-1px);box-shadow:0 4px 16px rgba(46,149,130,0.2)}
.bottom-cta .btn-primary{font-size:17px;padding:16px 36px;position:relative}

@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:0.01ms!important;animation-iteration-count:1!important;transition-duration:0.01ms!important}html{scroll-behavior:auto}}
@media(max-width:768px){
  :root{--section-pad-y:80px;--section-pad-x:24px}
  .page-hero{padding:48px 24px 56px}
  .partner-card{grid-template-columns:1fr;gap:16px}
  .choosing-layout{grid-template-columns:1fr}.choosing-visual{height:240px}
}
@media(max-width:420px){:root{--section-pad-x:16px;--section-pad-y:64px}.page-hero{padding:40px 16px 48px}.partner-card{padding:24px 20px}}
</style>
