---
import BaseLayout from '@layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import teamHuddle from '@assets/images/team-huddle.jpg';
import articlePremiums from '@assets/images/article-premiums.jpg';
import articleClaimsData from '@assets/images/article-claims-data.jpg';
import articleHrChallenges from '@assets/images/article-hr-challenges.jpg';
---

<BaseLayout
  title="Health Insurance Brokerage for Modern Businesses"
  description="Modern health insurance brokerage helping businesses take control of their benefits through proactive claims management and a concierge employee experience."
  canonicalPath="/"
>

<!-- HERO -->
<section class="hero" aria-label="Introduction">
  <div class="hero-blob hero-blob--elm" aria-hidden="true"></div>
  <div class="hero-blob hero-blob--gold" aria-hidden="true"></div>

  <div class="hero-eyebrow" aria-hidden="true">Health insurance, healed</div>
  <h1>Your benefits should work as hard as <em>you do</em></h1>
  <p class="hero-sub">Most companies overpay for health insurance because they've only been shown one option. There's a better way to protect your team and your bottom line.</p>
  <div class="hero-actions">
    <a href="/talk-to-us" class="btn-primary">See Your Options</a>
    <a href="/learn" class="btn-warm">Start Learning</a>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span class="hero-scroll-text">Scroll to explore</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<!-- PROBLEM — Layer 1: The Industry Problem -->
<section class="section problem" aria-labelledby="problem-heading">
  <div class="section-inner">
    <div class="problem-layout">
      <div>
        <div class="eyebrow">The industry problem</div>
        <h2 id="problem-heading">The system is optimized for the status quo, not for your company</h2>
        <p>Most brokers only quote fully funded plans because they're familiar, easy to manage, and keep everyone comfortable. Meanwhile, your premiums climb 10 to 30% every year.</p>
        <p>Health insurance is likely your second-largest expense after salaries. Very few businesses are being shown all their options.</p>
        <div class="problem-stats">
          <div class="problem-stat">
            <div class="number" aria-label="10 to 30 percent">10–30%</div>
            <div class="label">Typical annual<br>premium increase</div>
          </div>
          <div class="problem-stat">
            <div class="number" aria-label="Number two">#2</div>
            <div class="label">Largest business<br>expense after payroll</div>
          </div>
        </div>
      </div>
      <div class="problem-visual">
        <Image src={teamHuddle} alt="Small team working together around a table with warm natural light" width={800} height={600} loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- SOLUTION — Layer 2: The Alternative -->
<section class="section solution" aria-labelledby="solution-heading">
  <div class="section-inner">
    <div class="solution-header">
      <h2 id="solution-heading">A smarter approach to your company's health benefits</h2>
      <p>Proven plan structures that give your company financial control and give your employees a better healthcare experience.</p>
    </div>
    <div class="solution-grid">
      <div class="sol-card">
        <div class="sol-card-accent" style="background:linear-gradient(90deg,var(--elm-400),var(--elm-300))" aria-hidden="true"></div>
        <h3>Financial control</h3>
        <p>See where your healthcare dollars go. With the right plan structure, unused premiums can come back to your company instead of staying with the carrier.</p>
      </div>
      <div class="sol-card">
        <div class="sol-card-accent" style="background:linear-gradient(90deg,var(--sapphire-500),var(--sapphire-300))" aria-hidden="true"></div>
        <h3>Concierge experience</h3>
        <p>Your employees get real human guidance navigating the healthcare system. Better care decisions lead to better outcomes and smarter claims.</p>
      </div>
      <div class="sol-card">
        <div class="sol-card-accent" style="background:linear-gradient(90deg,var(--gold-500),var(--gold-300))" aria-hidden="true"></div>
        <h3>Proactive management</h3>
        <p>Claims don't manage themselves. We actively monitor and guide the process so your plan performs better every year, not worse.</p>
      </div>
    </div>
  </div>
</section>

<!-- SOCIAL PROOF BAR -->
<section class="proof" aria-label="Trust indicators">
  <div class="proof-inner">
    <div class="proof-item">
      <div class="proof-number">Utah-based</div>
      <div class="proof-label">Serving local businesses</div>
    </div>
    <div class="proof-dot" aria-hidden="true"></div>
    <div class="proof-item">
      <div class="proof-number">100%</div>
      <div class="proof-label">Commission transparency</div>
    </div>
    <div class="proof-dot" aria-hidden="true"></div>
    <div class="proof-item">
      <div class="proof-number">Year-round</div>
      <div class="proof-label">Ongoing partnership</div>
    </div>
  </div>
</section>

<!-- PERSONA ROUTER — Learning Tracks -->
<section class="section personas" aria-labelledby="persona-heading">
  <div class="section-inner">
    <div class="personas-header">
      <h2 id="persona-heading">Where would you like to start?</h2>
      <p>Two guided paths through benefits modernization, built for the people who make and manage the decision.</p>
    </div>
    <div class="persona-cards">
      <a href="/learn/business-case" class="persona-card persona-card--biz">
        <div class="role">For business leaders</div>
        <h3>The Business Case</h3>
        <p>The financial argument for rethinking your company's health benefits. From rising premiums to ROI modeling.</p>
        <div class="card-meta">
          <span>8 articles</span>
          <span>~60 min</span>
          <span>Beginner to Advanced</span>
        </div>
        <span class="card-link">Start the track <span aria-hidden="true">→</span></span>
      </a>
      <a href="/learn/hr-playbook" class="persona-card persona-card--hr">
        <div class="role">For HR professionals</div>
        <h3>The HR Playbook</h3>
        <p>What benefits modernization looks like operationally. Transitions, templates, and less admin work.</p>
        <div class="card-meta">
          <span>7 articles</span>
          <span>~55 min</span>
          <span>Beginner to Advanced</span>
        </div>
        <span class="card-link">Start the track <span aria-hidden="true">→</span></span>
      </a>
    </div>
  </div>
</section>

<!-- H.E.A.R.T. VALUES — Brand Section (Dark Elm) -->
<section class="section trust" aria-labelledby="trust-heading">
  <div class="section-inner trust-inner">
    <div class="trust-layout">
      <div class="trust-header">
        <h2 id="trust-heading">We serve with H.E.A.R.T.</h2>
        <p>Five values that change how we actually operate, not just what we put on a wall.</p>
      </div>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-card-top">
            <div class="value-letter" aria-hidden="true">H</div>
            <div class="value-name">Honor</div>
          </div>
          <div class="value-action"><strong>We disclose our commissions upfront.</strong> Every dollar, every incentive, in writing, before you sign anything. The Consolidated Appropriations Act requires it. We'd do it anyway.</div>
        </div>
        <div class="value-card">
          <div class="value-card-top">
            <div class="value-letter" aria-hidden="true">E</div>
            <div class="value-name">Excellence</div>
          </div>
          <div class="value-action"><strong>We use concierge tools, not call centers.</strong> Your employees get real human guidance navigating care. Not a phone tree. Not a chatbot. A person who knows their name.</div>
        </div>
        <div class="value-card">
          <div class="value-card-top">
            <div class="value-letter" aria-hidden="true">A</div>
            <div class="value-name">Accountability</div>
          </div>
          <div class="value-action"><strong>We share your claims data with you.</strong> Year-over-year performance tracking, transparent reporting, and honest assessments of what's working and what isn't. No black boxes.</div>
        </div>
        <div class="value-card">
          <div class="value-card-top">
            <div class="value-letter" aria-hidden="true">R</div>
            <div class="value-name">Respect</div>
          </div>
          <div class="value-action"><strong>We treat your benefits budget like our own money.</strong> Every recommendation starts with what's right for your company and your people. We'll tell you if staying on your current plan is the best option.</div>
        </div>
        <div class="value-card value-card--wide">
          <div class="value-card-top">
            <div class="value-letter" aria-hidden="true">T</div>
            <div class="value-name">Trust</div>
          </div>
          <div class="value-action"><strong>We're a year-round partner, not a once-a-year salesperson.</strong> Proactive check-ins, claims monitoring, and renewal strategy that starts months before your renewal date. You'll never wonder if we're paying attention.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EDUCATIONAL TEASER (White) -->
<section class="section edu-teaser" aria-labelledby="edu-heading">
  <div class="section-inner">
    <div class="edu-header">
      <h2 id="edu-heading">Start learning today</h2>
      <p>Practical articles that help you understand your options and make better decisions.</p>
    </div>
    <div class="edu-cards">
      <a href="/learn/business-case/why-premiums-keep-climbing" class="edu-card">
        <div class="edu-card-image">
          <Image src={articlePremiums} alt="Tax forms, financial documents, and calculator used for business premium cost analysis" width={600} height={400} loading="lazy" />
        </div>
        <div class="edu-card-body">
          <span class="edu-card-badge">Business Leaders</span>
          <div class="edu-card-title">Why Your Health Insurance Premiums Keep Climbing</div>
          <div class="edu-card-meta">Beginner · 5 min read</div>
        </div>
      </a>
      <a href="/learn/business-case/claims-data" class="edu-card">
        <div class="edu-card-image">
          <Image src={articleClaimsData} alt="Printed claims data charts and cost trend visualizations on a desk" width={600} height={400} loading="lazy" />
        </div>
        <div class="edu-card-body">
          <span class="edu-card-badge">Business Leaders</span>
          <div class="edu-card-title">Claims Data: What You Should Be Seeing (And Aren't)</div>
          <div class="edu-card-meta">Intermediate · 5 min read</div>
        </div>
      </a>
      <a href="/learn/hr-playbook/why-benefits-feel-hard" class="edu-card">
        <div class="edu-card-image">
          <Image src={articleHrChallenges} alt="HR leader reviewing employee benefits documentation in a modern office" width={600} height={400} loading="lazy" />
        </div>
        <div class="edu-card-body">
          <span class="edu-card-badge">HR Playbook</span>
          <div class="edu-card-title">Why Benefits Feel So Hard (It's Not You)</div>
          <div class="edu-card-meta">Beginner · 4 min read</div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- BOTTOM CTA (Dark) -->
<section class="bottom-cta" aria-labelledby="cta-heading">
  <h2 id="cta-heading">Ready to see what you've been missing?</h2>
  <p>A 30-minute conversation about your benefits. No pressure, no jargon, just options.</p>
  <a href="/talk-to-us" class="btn-primary">Talk to Us</a>
</section>

</BaseLayout>

<style>
/* ========================================
   HERO
   ======================================== */
.hero{
  min-height:70vh;display:flex;flex-direction:column;
  justify-content:center;align-items:center;text-align:center;
  padding:72px var(--section-pad-x) 64px;position:relative;overflow:hidden;
}
/* Ambient golden-hour light */
.hero::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 50% 30%, rgba(212,238,234,0.25) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 25% 70%, rgba(252,244,215,0.4) 0%, transparent 50%),
    radial-gradient(ellipse 50% 40% at 75% 75%, rgba(247,229,168,0.25) 0%, transparent 50%);
  pointer-events:none;
}
/* Sunrise gradient at bottom */
.hero::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:30%;
  background:linear-gradient(180deg,
    transparent 0%,
    rgba(225,196,94,0.06) 50%,
    rgba(201,168,58,0.1) 100%
  );
  pointer-events:none;
}

/* Organic ambient blobs */
.hero-blob{
  position:absolute;border-radius:60% 40% 50% 50% / 40% 50% 50% 60%;
  filter:blur(40px);pointer-events:none;
  animation:blobFloat 12s ease-in-out infinite;
}
.hero-blob--elm{
  top:8%;right:5%;width:300px;height:300px;
  background:var(--elm-100);opacity:0.12;
}
.hero-blob--gold{
  bottom:15%;left:8%;width:250px;height:250px;
  background:var(--gold-200);opacity:0.15;
  filter:blur(50px);
  animation-duration:15s;animation-direction:reverse;
  border-radius:50% 60% 40% 50% / 60% 40% 50% 50%;
}

.hero-eyebrow{
  font-size:12px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;
  color:var(--gold-800);margin-bottom:28px;position:relative;z-index:1;
  display:flex;align-items:center;gap:12px;
  opacity:0;animation:fadeUp 0.6s 0.2s forwards;
}
.hero-eyebrow::before,.hero-eyebrow::after{
  content:'';width:24px;height:1px;background:var(--gold-500);
}

.hero h1{
  font-family:var(--font-display);font-size:clamp(40px,6vw,78px);
  font-weight:700;line-height:1.06;letter-spacing:-0.03em;
  color:var(--nero-900);max-width:840px;margin-bottom:28px;
  position:relative;z-index:1;
  opacity:0;animation:fadeUp 0.6s 0.35s forwards;
}
.hero h1 em{
  font-style:italic;
  background:linear-gradient(135deg, var(--elm-600), var(--elm-500));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}

.hero-sub{
  font-size:clamp(16px,1.8vw,20px);line-height:1.65;color:var(--nero-500);
  max-width:540px;margin-bottom:36px;position:relative;z-index:1;
  opacity:0;animation:fadeUp 0.6s 0.5s forwards;
}

.hero-actions{
  display:flex;gap:16px;align-items:center;position:relative;z-index:1;
  flex-wrap:wrap;justify-content:center;
  opacity:0;animation:fadeUp 0.6s 0.65s forwards;
}

.hero-scroll{
  margin-top:48px;z-index:1;
  display:flex;flex-direction:column;align-items:center;gap:4px;
  opacity:0;animation:fadeUp 0.6s 1s forwards;
}
.hero-scroll-text{font-size:12px;font-weight:500;color:var(--gold-600);letter-spacing:0.05em}
.hero-scroll-line{
  width:1px;height:32px;
  background:linear-gradient(180deg,var(--gold-400),transparent);
  animation:scrollPulse 2s infinite;
}

/* ========================================
   PROBLEM SECTION (Linen)
   ======================================== */
.problem{background:var(--warm-linen)}
.problem-layout{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.problem .eyebrow{color:var(--elm-600)}
.problem h2{
  font-family:var(--font-display);font-size:clamp(28px,3.5vw,42px);
  font-weight:700;line-height:1.15;letter-spacing:-0.02em;margin-bottom:24px;
}
.problem p{font-size:17px;line-height:1.7;color:var(--nero-600);margin-bottom:20px}
.problem-stats{display:flex;gap:48px;margin-top:40px}
.problem-stat .number{
  font-family:var(--font-display);font-size:48px;font-weight:700;
  background:linear-gradient(135deg, var(--elm-500), var(--elm-400));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;line-height:1;
}
.problem-stat .label{font-size:13px;color:var(--nero-500);margin-top:4px}

.problem-visual{
  border-radius:20px;height:420px;position:relative;overflow:hidden;
  box-shadow:0 20px 60px rgba(38,35,36,0.06);
}
.problem-visual img{width:100%;height:100%;object-fit:cover;display:block}

/* ========================================
   SOLUTION SECTION (Cream)
   ======================================== */
.solution{background:var(--warm-cream)}
.solution-header{text-align:center;max-width:640px;margin:0 auto 64px}
.solution-header h2{
  font-family:var(--font-display);font-size:clamp(28px,3.5vw,42px);
  font-weight:700;line-height:1.15;letter-spacing:-0.02em;margin-bottom:16px;
}
.solution-header p{font-size:17px;line-height:1.7;color:var(--nero-500)}

.solution-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.sol-card{
  padding:36px 32px;background:#fff;
  border:1px solid var(--nero-100);border-radius:14px;
  transition:all var(--t-med);position:relative;overflow:hidden;
  box-shadow:0 1px 3px rgba(38,35,36,0.04);
}
.sol-card:hover{
  transform:translateY(-4px);
  box-shadow:0 12px 36px rgba(38,35,36,0.08);
  border-color:var(--elm-200);
}
.sol-card-accent{width:40px;height:3px;border-radius:2px;margin-bottom:24px}
.sol-card h3{
  font-family:var(--font-display);font-size:20px;font-weight:700;
  margin-bottom:12px;line-height:1.3;
}
.sol-card p{font-size:15px;line-height:1.65;color:var(--nero-600)}

/* ========================================
   SOCIAL PROOF BAR (Elm-50 tinted)
   ======================================== */
.proof{
  padding:80px var(--section-pad-x);
  background:var(--elm-50);
  border-top:1px solid var(--elm-100);
  border-bottom:1px solid var(--elm-100);
}
.proof-inner{
  max-width:900px;margin:0 auto;
  display:flex;justify-content:center;gap:64px;align-items:center;
}
.proof-item{text-align:center}
.proof-number{
  font-family:var(--font-display);font-size:36px;font-weight:700;
  color:var(--elm-700);line-height:1;
}
.proof-label{font-size:13px;color:var(--elm-800);margin-top:6px;max-width:140px;opacity:0.7}
.proof-dot{width:1px;height:48px;background:var(--elm-200)}

/* ========================================
   PERSONA ROUTER (Linen)
   ======================================== */
.personas{background:var(--warm-linen);border-top:1px solid rgba(204,201,199,0.2)}
.personas-header{text-align:center;max-width:560px;margin:0 auto 56px}
.personas-header h2{
  font-family:var(--font-display);font-size:clamp(28px,3.5vw,38px);
  font-weight:700;line-height:1.15;letter-spacing:-0.02em;margin-bottom:12px;
}
.personas-header p{font-size:16px;color:var(--nero-500);line-height:1.6}

.persona-cards{display:grid;grid-template-columns:1fr 1fr;gap:28px;max-width:920px;margin:0 auto}
.persona-card{
  background:#fff;border-radius:18px;
  padding:44px 36px;transition:all var(--t-med);cursor:pointer;
  position:relative;overflow:hidden;
  box-shadow:0 2px 8px rgba(38,35,36,0.04);
  text-decoration:none;display:block;
}
.persona-card:hover{
  transform:translateY(-4px);
  box-shadow:0 12px 36px rgba(38,35,36,0.08);
}
.persona-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:4px;
}
.persona-card--biz::before{background:linear-gradient(90deg, var(--elm-400), var(--elm-300))}
.persona-card--hr::before{background:linear-gradient(90deg, var(--gold-400), var(--gold-300))}

.persona-card .role{
  font-size:12px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;
  margin-bottom:16px;
}
.persona-card--biz .role{color:var(--elm-600)}
.persona-card--hr .role{color:var(--gold-800)}

.persona-card h3{
  font-family:var(--font-display);font-size:24px;font-weight:700;
  margin-bottom:12px;line-height:1.25;
}
.persona-card p{font-size:15px;line-height:1.65;color:var(--nero-600);margin-bottom:20px}
.card-meta{font-size:12px;color:var(--nero-400);margin-bottom:20px;display:flex;gap:12px}
.card-link{
  font-size:14px;font-weight:600;color:var(--sapphire-500);text-decoration:none;
  display:inline-flex;align-items:center;gap:6px;
  transition:gap var(--t-fast);
}
.persona-card:hover .card-link{gap:10px}

/* ========================================
   H.E.A.R.T. VALUES (Brand dark section)
   ======================================== */
.trust{
  background:linear-gradient(135deg, var(--elm-700) 0%, var(--elm-600) 100%);
  color:#fff;position:relative;overflow:hidden;
}
.trust::before{
  content:'';position:absolute;top:-20%;right:-10%;
  width:500px;height:500px;border-radius:50%;
  background:radial-gradient(ellipse, rgba(225,196,94,0.08) 0%, transparent 60%);
  pointer-events:none;
}
.trust-inner{position:relative;z-index:1}
.trust-layout{max-width:960px;margin:0 auto}
.trust-header{max-width:700px;margin:0 auto 56px;text-align:center}
.trust-header h2{
  font-family:var(--font-display);font-size:clamp(28px,3.5vw,40px);
  font-weight:700;line-height:1.15;margin-bottom:12px;
}
.trust-header p{font-size:16px;color:var(--elm-100);line-height:1.65}

.values-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:960px;margin:0 auto}
.value-card{
  background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);
  border-radius:14px;padding:28px 28px 24px;transition:all 200ms;
}
.value-card:hover{background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.14)}
.value-card-top{display:flex;align-items:center;gap:14px;margin-bottom:12px}
.value-letter{
  font-family:var(--font-display);font-size:28px;font-weight:700;
  color:var(--gold-400);line-height:1;
}
.value-name{font-size:16px;font-weight:700;color:#fff}
.value-action{font-size:14px;color:var(--elm-100);line-height:1.6}
.value-action strong{color:#fff;font-weight:600}
.value-card--wide{grid-column:1 / -1}

/* ========================================
   EDUCATIONAL TEASER (White)
   ======================================== */
.edu-teaser{background:#fff;border-top:1px solid rgba(204,201,199,0.2)}
.edu-header{text-align:center;max-width:560px;margin:0 auto 48px}
.edu-header h2{
  font-family:var(--font-display);font-size:clamp(24px,3vw,34px);
  font-weight:700;line-height:1.2;margin-bottom:12px;
}
.edu-header p{font-size:16px;color:var(--nero-500)}

.edu-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:var(--inner-max);margin:0 auto}
.edu-card{
  background:#fff;border-radius:14px;overflow:hidden;
  box-shadow:0 2px 8px rgba(38,35,36,0.04);border:1px solid var(--nero-100);
  transition:all var(--t-med);text-decoration:none;display:block;color:inherit;
}
.edu-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(38,35,36,0.08)}
.edu-card-image{
  height:140px;overflow:hidden;
}
.edu-card-image img{width:100%;height:100%;object-fit:cover;display:block}
.edu-card:nth-child(1) .edu-card-image{background:var(--elm-50)}
.edu-card:nth-child(2) .edu-card-image{background:var(--sapphire-50)}
